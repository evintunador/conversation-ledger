{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\timport { mkdir, readFile, rm, writeFile } from \"node:fs/promises\";\n2\timport { existsSync } from \"node:fs\";\n3\timport { join } from \"node:path\";\n4\timport { canonicalJson, sha256Hex } from \"./canonical.js\";\n5\timport {\n6\t  currentBranch,\n7\t  git,\n8\t  gitUserIdentity,\n9\t  headSha,\n10\t  repoIdentity,\n11\t  revList,\n12\t  statusPorcelain,\n13\t  type RepoInfo,\n14\t} from \"./git.js\";\n15\timport {\n16\t  absorbIncoming,\n17\t  ensureMergeConfig,\n18\t  ensureTransport,\n19\t  INCOMING_REF,\n20\t  NOTES_NAME,\n21\t  NOTES_REF,\n22\t} from \"./transport.js\";\n23\timport {\n24\t  finalizeEvent,\n25\t  parseEventLine,\n26\t  serializeEvent,\n27\t  type Actor,\n28\t  type EventDraft,\n29\t  type EvidenceEvent,\n30\t  type RepoContext,\n31\t} from \"./schema.js\";\n32\timport { redactDraft, type RedactionRecord } from \"./redact/apply.js\";\n33\timport { captureRules, collectEnvValues, loadConfig } from \"./redact/config.js\";\n34\timport { RULESET_VERSION, type RedactionRule } from \"./redact/rules.js\";\n35\timport { filterFindings, formatFinding, loadAllowlist, scanEvents } from \"./redact/scan.js\";\n36\t\n37\texport { ensureMergeConfig, NOTES_NAME, NOTES_REF } from \"./transport.js\";\n38\t\n39\t/**\n40\t * Storage model: one git note per anchor commit under refs/notes/\n41\t * conversation-ledger. The note body is JSONL — one canonical-JSON event\n42\t * per line, lexicographically sorted, unique. Everything lives in the note\n43\t * blob itself (no out-of-tree pointers), so records are reachable from the\n44\t * ref, GC-safe, travel with `git push`/`fetch` of that one ref, and merge\n45\t * conflict-free with the cat_sort_uniq notes strategy.\n46\t *\n47\t * Events are anchored to HEAD at capture time, so conversations ride the\n48\t * commit DAG: merge a branch and its conversations become reachable from\n49\t * the target branch with no extra machinery.\n50\t */\n51\t\n52\tfunction stateDir(repo: RepoInfo): string {\n53\t  return join(repo.gitDir, \"conversation-ledger\");\n54\t}\n55\t\n56\tfunction pendingPath(repo: RepoInfo): string {\n57\t  return join(stateDir(repo), \"pending.jsonl\");\n58\t}\n59\t\n60\t/** Local, rebuildable cache/state only — never the record of truth. */\n61\tasync function ensureStateDir(repo: RepoInfo): Promise<void> {\n62\t  await mkdir(stateDir(repo), { recursive: true });\n63\t}\n64\t\n65\texport async function captureContext(repo: RepoInfo): Promise<RepoContext> {\n66\t  const [identity, branch, head, status] = await Promise.all([\n67\t    repoIdentity(repo),\n68\t    currentBranch(repo),\n69\t    headSha(repo),\n70\t    statusPorcelain(repo),\n71\t  ]);\n72\t  const context: RepoContext = { repo: identity, cwd: repo.root };\n73\t  if (branch) context.branch = branch;\n74\t  if (head) context.head = head;\n75\t  if (status.trim()) context.dirty_fingerprint = sha256Hex(status);\n76\t  return context;\n77\t}\n78\t\n79\tasync function readNoteLines(repo: RepoInfo, anchor: string, refName = NOTES_NAME): Promise<string[]> {\n80\t  const body = await git([\"notes\", \"--ref\", refName, \"show\", anchor], {\n81\t    cwd: repo.root,\n82\t    allowFailure: true,\n83\t  });\n84\t  return body.split(\"\\n\").filter((l) => l.trim().length > 0);\n85\t}\n86\t\n87\t/** `refName` defaults to the main ledger ref; the scan gate also reads a temp fetched ref. */\n88\texport async function readNoteEvents(\n89\t  repo: RepoInfo,\n90\t  anchor: string,\n91\t  refName = NOTES_NAME,\n92\t): Promise<EvidenceEvent[]> {\n93\t  return (await readNoteLines(repo, anchor, refName)).map(parseEventLine);\n94\t}\n95\t\n96\t/** All (anchor commit, note) pairs in the ledger ref (or `refName`, for reading a temp fetched ref). */\n97\texport async function listAnchors(repo: RepoInfo, refName = NOTES_NAME): Promise<string[]> {\n98\t  const out = await git([\"notes\", \"--ref\", refName, \"list\"], {\n99\t    cwd: repo.root,\n100\t    allowFailure: true,\n101\t  });\n102\t  return out\n103\t    .split(\"\\n\")\n104\t    .filter(Boolean)\n105\t    .map((line) => line.split(/\\s+/)[1])\n106\t    .filter((sha): sha is string => Boolean(sha));\n107\t}\n108\t\n109\tasync function withLock<T>(repo: RepoInfo, fn: () => Promise<T>): Promise<T> {\n110\t  await ensureStateDir(repo);\n111\t  const lockDir = join(stateDir(repo), \"lock\");\n112\t  const deadline = Date.now() + 10_000;\n113\t  for (;;) {\n114\t    try {\n115\t      await mkdir(lockDir);\n116\t      break;\n117\t    } catch {\n118\t      if (Date.now() > deadline) {\n119\t        // A crashed writer can leave the lock behind; steal it after the\n120\t        // wait budget rather than wedging capture hooks forever.\n121\t        await rm(lockDir, { recursive: true, force: true });\n122\t      } else {\n123\t        await new Promise((r) => setTimeout(r, 100));\n124\t      }\n125\t    }\n126\t  }\n127\t  try {\n128\t    return await fn();\n129\t  } finally {\n130\t    await rm(lockDir, { recursive: true, force: true });\n131\t  }\n132\t}\n133\t\n134\texport interface AppendResult {\n135\t  appended: EvidenceEvent[];\n136\t  deduped: number;\n137\t  /** null when events went to the pending queue (unborn HEAD). */\n138\t  anchor: string | null;\n139\t}\n140\t\n141\texport async function appendEvents(\n142\t  repo: RepoInfo,\n143\t  drafts: EventDraft[],\n144\t  opts: { context?: RepoContext } = {},\n145\t): Promise<AppendResult> {\n146\t  const context = opts.context ?? (await captureContext(repo));\n147\t  const config = await loadConfig(repo.root);\n148\t  // First capture in a repo wires up transport (pre-push hook + fetch\n149\t  // refspec); later calls are cheap re-checks. Never throws.\n150\t  await ensureTransport(repo, config);\n151\t  const rules = captureRules(config);\n152\t  const extraValues =\n153\t    rules.length > 0 && config.redact?.env === true\n154\t      ? await collectEnvValues(repo.root)\n155\t      : undefined;\n156\t  const events = drafts.map((draft) => {\n157\t    const withContext = { ...draft, context: draft.context ?? context };\n158\t    if (rules.length === 0) return finalizeEvent(withContext);\n159\t    const { draft: redacted, records } = redactDraft(withContext, {\n160\t      rules,\n161\t      ...(extraValues ? { extraValues } : {}),\n162\t    });\n163\t    return finalizeEvent(records.length > 0 ? { ...redacted, redactions: records } : redacted);\n164\t  });\n165\t  return withLock(repo, async () => {\n166\t    await ensureMergeConfig(repo);\n167\t    const anchor = await headSha(repo);\n168\t    if (!anchor) {\n169\t      return appendPending(repo, events);\n170\t    }\n171\t    const pending = await drainPending(repo);\n172\t    const existing = await readNoteLines(repo, anchor);\n173\t    const known = new Set(existing.map((l) => parseEventLine(l).id));\n174\t    const fresh = [...pending, ...events].filter((e) => {\n175\t      if (known.has(e.id)) return false;\n176\t      known.add(e.id);\n177\t      return true;\n178\t    });\n179\t    if (fresh.length === 0) {\n180\t      return { appended: [], deduped: events.length, anchor };\n181\t    }\n182\t    const lines = [...existing, ...fresh.map(serializeEvent)].sort();\n183\t    await git([\"notes\", \"--ref\", NOTES_NAME, \"add\", \"-f\", \"-F\", \"-\", anchor], {\n184\t      cwd: repo.root,\n185\t      input: lines.join(\"\\n\") + \"\\n\",\n186\t    });\n187\t    const freshIds = new Set(fresh.map((e) => e.id));\n188\t    return {\n189\t      appended: events.filter((e) => freshIds.has(e.id)),\n190\t      deduped: events.length - events.filter((e) => freshIds.has(e.id)).length,\n191\t      anchor,\n192\t    };\n193\t  });\n194\t}\n195\t\n196\tasync function appendPending(repo: RepoInfo, events: EvidenceEvent[]): Promise<AppendResult> {\n197\t  await ensureStateDir(repo);\n198\t  const path = pendingPath(repo);\n199\t  const existing = existsSync(path)\n200\t    ? (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean)\n201\t    : [];\n202\t  const known = new Set(existing.map((l) => parseEventLine(l).id));\n203\t  const fresh = events.filter((e) => !known.has(e.id));\n204\t  await writeFile(path, [...existing, ...fresh.map(serializeEvent)].join(\"\\n\") + \"\\n\");\n205\t  return { appended: fresh, deduped: events.length - fresh.length, anchor: null };\n206\t}\n207\t\n208\t/** Events held while HEAD was unborn; caller writes them into a real note. */\n209\tasync function drainPending(repo: RepoInfo): Promise<EvidenceEvent[]> {\n210\t  const path = pendingPath(repo);\n211\t  if (!existsSync(path)) return [];\n212\t  const events = (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean).map(parseEventLine);\n213\t  await rm(path, { force: true });\n214\t  return events;\n215\t}\n216\t\n217\texport async function readPending(repo: RepoInfo): Promise<EvidenceEvent[]> {\n218\t  const path = pendingPath(repo);\n219\t  if (!existsSync(path)) return [];\n220\t  return (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean).map(parseEventLine);\n221\t}\n222\t\n223\texport interface ReadOptions {\n224\t  /** Restrict to events anchored to commits reachable from this rev. */\n225\t  reachableFrom?: string;\n226\t  kind?: string;\n227\t  source?: string;\n228\t  conversation?: string;\n229\t}\n230\t\n231\texport async function readEvents(repo: RepoInfo, opts: ReadOptions = {}): Promise<EvidenceEvent[]> {\n232\t  // Lazy transport: fold in anything a plain `git fetch`/`git pull` staged.\n233\t  await absorbIncoming(repo);\n234\t  let anchors = await listAnchors(repo);\n235\t  if (opts.reachableFrom) {\n236\t    const reachable = await revList(repo, opts.reachableFrom);\n237\t    anchors = anchors.filter((a) => reachable.has(a));\n238\t  }\n239\t  const events: EvidenceEvent[] = [];\n240\t  for (const anchor of anchors) {\n241\t    events.push(...(await readNoteEvents(repo, anchor)));\n242\t  }\n243\t  events.push(...(await readPending(repo)));\n244\t  const filtered = events.filter(\n245\t    (e) =>\n246\t      (!opts.kind || e.kind === opts.kind) &&\n247\t      (!opts.source || e.producer.source === opts.source) &&\n248\t      (!opts.conversation || e.conversation?.id === opts.conversation ||\n249\t        e.conversation?.id.startsWith(opts.conversation)),\n250\t  );\n251\t  return sortEvents(filtered);\n252\t}\n253\t\n254\t/** Stable order: conversation, then seq, then time, then id. */\n255\texport function sortEvents(events: EvidenceEvent[]): EvidenceEvent[] {\n256\t  return [...events].sort((a, b) => {\n257\t    const conv = (a.conversation?.id ?? \"\").localeCompare(b.conversation?.id ?? \"\");\n258\t    if (conv !== 0) return conv;\n259\t    const seq = (a.conversation?.seq ?? 0) - (b.conversation?.seq ?? 0);\n260\t    if (seq !== 0) return seq;\n261\t    const time = a.occurred_at.localeCompare(b.occurred_at);\n262\t    if (time !== 0) return time;\n263\t    return a.id.localeCompare(b.id);\n264\t  });\n265\t}\n266\t\n267\texport interface SyncResult {\n268\t  fetched: boolean;\n269\t  pushed: boolean;\n270\t}\n271\t\n272\t/**\n273\t * Event ids the remote's notes ref already has, fetched into a throwaway\n274\t * temp ref that is deleted before returning. Null means the remote has no\n275\t * ledger ref at all (e.g. first push), in which case the caller should\n276\t * treat everything local as unshared.\n277\t */\n278\tasync function remoteNoteIds(repo: RepoInfo, remote: string): Promise<Set<string> | null> {\n279\t  const remoteHasRef = (await git([\"ls-remote\", remote, NOTES_REF], {\n280\t    cwd: repo.root,\n281\t    allowFailure: true,\n282\t  })).trim();\n283\t  if (!remoteHasRef) return null;\n284\t\n285\t  const tmpName = \"conversation-ledger-scan-tmp\";\n286\t  const tmpRef = `refs/notes/${tmpName}`;\n287\t  await git([\"fetch\", remote, `+${NOTES_REF}:${tmpRef}`], { cwd: repo.root, allowFailure: true });\n288\t  try {\n289\t    const ids = new Set<string>();\n290\t    for (const anchor of await listAnchors(repo, tmpName)) {\n291\t      for (const event of await readNoteEvents(repo, anchor, tmpName)) ids.add(event.id);\n292\t    }\n293\t    return ids;\n294\t  } finally {\n295\t    await git([\"update-ref\", \"-d\", tmpRef], { cwd: repo.root, allowFailure: true });\n296\t  }\n297\t}\n298\t\n299\t/** Thrown when the layer-E scan gate blocks a push; carries no secrets. */\n300\texport class ScanBlockedError extends Error {\n301\t  constructor(public readonly findings: number) {\n302\t    super(`cledger sync: push blocked — ${findings} potential secret(s) found (see report above)`);\n303\t  }\n304\t}\n305\t\n306\t/**\n307\t * Layer E: before push, scan only the events the remote does not yet have\n308\t * (already-pushed events are not rescanned every time). On any surviving\n309\t * finding, print a report and throw so sync() does not proceed to push —\n310\t * the fetch/merge phase, if it already ran, is left in place.\n311\t */\n312\tasync function runScanGate(repo: RepoInfo, remote: string, tier: \"standard\" | \"paranoid\"): Promise<void> {\n313\t  const remoteIds = await remoteNoteIds(repo, remote);\n314\t\n315\t  const localEvents: EvidenceEvent[] = [];\n316\t  for (const anchor of await listAnchors(repo)) {\n317\t    localEvents.push(...(await readNoteEvents(repo, anchor)));\n318\t  }\n319\t  localEvents.push(...(await readPending(repo)));\n320\t\n321\t  const candidates = remoteIds ? localEvents.filter((e) => !remoteIds.has(e.id)) : localEvents;\n322\t  if (candidates.length === 0) return;\n323\t\n324\t  const findings = filterFindings(scanEvents(candidates, tier), await loadAllowlist(repo));\n325\t  if (findings.length === 0) return;\n326\t\n327\t  process.stderr.write(\n328\t    `cledger sync: blocked — ${findings.length} potential secret(s) in event(s) not yet on ${remote}\\n\\n`,\n329\t  );\n330\t  for (const f of findings) process.stderr.write(`  ${formatFinding(f)}\\n`);\n331\t  process.stderr.write(\n332\t    \"\\nRemediate, then re-run sync:\\n\" +\n333\t      \"  cledger redact <event-id>     rewrite the event and remove the secret\\n\" +\n334\t      \"  cledger allow <fingerprint>   mark a fingerprint as a known false positive\\n\" +\n335\t      \"  cledger sync --no-scan        skip this gate for this sync only\\n\",\n336\t  );\n337\t  throw new ScanBlockedError(findings.length);\n338\t}\n339\t\n340\t/**\n341\t * Sync of the single ledger ref: explicit via `cledger sync`, or run by the\n342\t * pre-push transport hook (see transportPush). The fetch phase stages into\n343\t * INCOMING_REF and absorbs it — the same path a plain `git fetch` plus a\n344\t * later read takes.\n345\t */\n346\texport async function sync(\n347\t  repo: RepoInfo,\n348\t  remote = \"origin\",\n349\t  mode: \"both\" | \"push\" | \"fetch\" = \"both\",\n350\t  opts: { skipScan?: boolean; paranoid?: boolean } = {},\n351\t): Promise<SyncResult> {\n352\t  const result: SyncResult = { fetched: false, pushed: false };\n353\t  await ensureMergeConfig(repo);\n354\t  if (mode !== \"push\") {\n355\t    await git(\n356\t      [\"fetch\", remote, `+${NOTES_REF}:${INCOMING_REF}`],\n357\t      { cwd: repo.root, allowFailure: true },\n358\t    );\n359\t    result.fetched = await absorbIncoming(repo);\n360\t  }\n361\t  if (mode !== \"fetch\") {\n362\t    const config = await loadConfig(repo.root);\n363\t    const scanDisabled = opts.skipScan === true || config.scan?.tier === \"off\";\n364\t    if (!scanDisabled) {\n365\t      const tier: \"standard\" | \"paranoid\" =\n366\t        opts.paranoid === true || config.scan?.tier === \"paranoid\" ? \"paranoid\" : \"standard\";\n367\t      await runScanGate(repo, remote, tier);\n368\t    }\n369\t    // The pushed child git inherits CLEDGER_INTERNAL, telling the pre-push\n370\t    // transport hook this push *is* the ledger push — no recursion.\n371\t    const prior = process.env[\"CLEDGER_INTERNAL\"];\n372\t    process.env[\"CLEDGER_INTERNAL\"] = \"1\";\n373\t    try {\n374\t      await git([\"push\", remote, `${NOTES_REF}:${NOTES_REF}`], { cwd: repo.root });\n375\t    } finally {\n376\t      if (prior === undefined) delete process.env[\"CLEDGER_INTERNAL\"];\n377\t      else process.env[\"CLEDGER_INTERNAL\"] = prior;\n378\t    }\n379\t    result.pushed = true;\n380\t  }\n381\t  return result;\n382\t}\n383\t\n384\texport interface TransportPushResult {\n385\t  pushed: boolean;\n386\t  /** True when scan findings held the ledger back (non-strict mode). */\n387\t  held: boolean;\n388\t}\n389\t\n390\t/**\n391\t * Pre-push hook entrypoint policy. Pushes the ledger ref alongside the\n392\t * user's own push. A scan finding blocks only the ledger by default —\n393\t * secrets never leave the machine, but a false positive never blocks\n394\t * shipping code; {\"transport\": {\"strict\": true}} escalates to aborting the\n395\t * whole push (rethrows ScanBlockedError; the CLI exits nonzero). Any other\n396\t * failure (network, missing remote ref perms) warns and lets the push\n397\t * proceed — the hook must never make `git push` flaky.\n398\t */\n399\texport async function transportPush(repo: RepoInfo, remote: string): Promise<TransportPushResult> {\n400\t  const config = await loadConfig(repo.root);\n401\t  if (config.transport?.hook === false) return { pushed: false, held: false };\n402\t  const hasNotes = (await git([\"rev-parse\", \"--verify\", \"--quiet\", NOTES_REF], {\n403\t    cwd: repo.root,\n404\t    allowFailure: true,\n405\t  })).trim();\n406\t  if (!hasNotes) return { pushed: false, held: false };\n407\t\n408\t  try {\n409\t    await sync(repo, remote, \"push\");\n410\t    return { pushed: true, held: false };\n411\t  } catch (err) {\n412\t    if (err instanceof ScanBlockedError) {\n413\t      if (config.transport?.strict === true) throw err;\n414\t      process.stderr.write(\n415\t        \"cledger: conversation records were held back from this push (potential secrets — \" +\n416\t          \"see report above); your code push continues. Run `cledger sync` to review and \" +\n417\t          \"remediate.\\n\",\n418\t      );\n419\t      return { pushed: false, held: true };\n420\t    }\n421\t    process.stderr.write(\n422\t      `cledger: ledger push skipped (${err instanceof Error ? err.message : String(err)})\\n`,\n423\t    );\n424\t    return { pushed: false, held: false };\n425\t  }\n426\t}\n427\t\n428\tinterface LocatedEvent {\n429\t  event: EvidenceEvent;\n430\t  /** Anchor commit holding the note line, or null when the event is still in pending.jsonl. */\n431\t  anchor: string | null;\n432\t  /** Full line array of the containing note (or of pending.jsonl), for in-place rewrite. */\n433\t  lines: string[];\n434\t  index: number;\n435\t}\n436\t\n437\tfunction idMatchesPrefix(id: string, prefix: string): boolean {\n438\t  if (id.startsWith(prefix)) return true;\n439\t  const hash = id.startsWith(\"ev1-\") ? id.slice(4) : id;\n440\t  return hash.startsWith(prefix);\n441\t}\n442\t\n443\t/** Find the one event matching `idPrefix` across every anchor and the pending queue. */\n444\tasync function locateEvent(repo: RepoInfo, idPrefix: string): Promise<LocatedEvent> {\n445\t  const matches: LocatedEvent[] = [];\n446\t\n447\t  for (const anchor of await listAnchors(repo)) {\n448\t    const lines = await readNoteLines(repo, anchor);\n449\t    lines.forEach((line, index) => {\n450\t      const event = parseEventLine(line);\n451\t      if (idMatchesPrefix(event.id, idPrefix)) matches.push({ event, anchor, lines, index });\n452\t    });\n453\t  }\n454\t\n455\t  const pendingFile = pendingPath(repo);\n456\t  const pendingLines = existsSync(pendingFile)\n457\t    ? (await readFile(pendingFile, \"utf8\")).split(\"\\n\").filter((l) => l.trim().length > 0)\n458\t    : [];\n459\t  pendingLines.forEach((line, index) => {\n460\t    const event = parseEventLine(line);\n461\t    if (idMatchesPrefix(event.id, idPrefix)) matches.push({ event, anchor: null, lines: pendingLines, index });\n462\t  });\n463\t\n4