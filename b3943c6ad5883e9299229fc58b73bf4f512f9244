{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\t#!/usr/bin/env node\n2\timport { readFileSync } from \"node:fs\";\n3\timport { stdin as input } from \"node:process\";\n4\timport { findRepo, type RepoInfo } from \"./git.js\";\n5\timport {\n6\t  appendEvents,\n7\t  readEvents,\n8\t  redactEvent,\n9\t  ScanBlockedError,\n10\t  sortEvents,\n11\t  sync,\n12\t  transportPush,\n13\t  type ReadOptions,\n14\t} from \"./store.js\";\n15\timport { parseEventLine, type EventDraft, type EvidenceEvent } from \"./schema.js\";\n16\timport { runClaudeCodeHook, captureClaudeTranscript } from \"./adapters/claude-code.js\";\n17\timport { runCodexHook, captureCodexTranscript } from \"./adapters/codex.js\";\n18\timport { installAdapters } from \"./install.js\";\n19\timport {\n20\t  addToAllowlist,\n21\t  filterFindings,\n22\t  formatFinding,\n23\t  loadAllowlist,\n24\t  scanEvents,\n25\t} from \"./redact/scan.js\";\n26\t\n27\tconst USAGE = `conversation-ledger — durable records of coding-agent conversations, in git notes\n28\t\n29\tUsage:\n30\t  cledger append [--quiet]                 append JSONL events/drafts from stdin\n31\t  cledger log [--all|--rev R] [--kind K] [--source S] [--conversation C] [--json]\n32\t  cledger show <conversation-id-prefix> [--json]\n33\t  cledger conversations [--rev R]         list conversations on current branch (--all for every branch)\n34\t  cledger export [--rev R]                lossless JSONL dump (default: everything)\n35\t  cledger sync [--remote R] [--push|--fetch] [--no-scan] [--paranoid]\n36\t                                           fetch/merge/push of the ledger ref;\n37\t                                           push is gated by a secret scan unless --no-scan\n38\t  cledger transport-push [remote]         pre-push hook entrypoint (installed automatically):\n39\t                                           pushes the ledger ref alongside git push; scan findings\n40\t                                           hold back only the ledger unless transport.strict\n41\t  cledger scan [--all|--rev R] [--paranoid]   scan local events for potential secrets (CI-friendly:\n42\t                                           exits 1 if any finding, 0 otherwise); default scope is\n43\t                                           every local event, --rev restricts by reachability\n44\t  cledger allow <fingerprint...>          mark scan finding fingerprint(s) as known false positives\n45\t  cledger redact <event-id-prefix> (--pattern REGEX | --all) [--reason TEXT]\n46\t                                           rewrite an existing event to remove a secret, keeping its\n47\t                                           id stable, and squash local notes history if unpushed\n48\t  cledger install <claude-code|codex|all>  hook capture into coding CLIs (global)\n49\t  cledger hook <claude-code>              capture entrypoint invoked by CLI hooks (stdin: hook payload)\n50\t  cledger capture <claude-code|codex> --transcript PATH   manual/backfill ingestion\n51\t  cledger --version | --help\n52\t\n53\tEvents are anchored to the HEAD commit at capture time and stored under\n54\trefs/notes/conversation-ledger, so they follow branches through merges and\n55\tsync only when you say so.`;\n56\t\n57\tfunction version(): string {\n58\t  const pkg = JSON.parse(\n59\t    readFileSync(new URL(\"../package.json\", import.meta.url), \"utf8\"),\n60\t  ) as { version: string };\n61\t  return pkg.version;\n62\t}\n63\t\n64\tinterface Flags {\n65\t  [key: string]: string | boolean;\n66\t}\n67\t\n68\tfunction parseArgs(argv: string[]): { positional: string[]; flags: Flags } {\n69\t  const positional: string[] = [];\n70\t  const flags: Flags = {};\n71\t  for (let i = 0; i < argv.length; i++) {\n72\t    const arg = argv[i]!;\n73\t    if (arg.startsWith(\"--\")) {\n74\t      const name = arg.slice(2);\n75\t      const next = argv[i + 1];\n76\t      if (next !== undefined && !next.startsWith(\"--\")) {\n77\t        flags[name] = next;\n78\t        i++;\n79\t      } else {\n80\t        flags[name] = true;\n81\t      }\n82\t    } else {\n83\t      positional.push(arg);\n84\t    }\n85\t  }\n86\t  return { positional, flags };\n87\t}\n88\t\n89\tasync function requireRepo(): Promise<RepoInfo> {\n90\t  const repo = await findRepo(process.cwd());\n91\t  if (!repo) {\n92\t    process.stderr.write(\"cledger: not inside a git repository\\n\");\n93\t    process.exit(2);\n94\t  }\n95\t  return repo;\n96\t}\n97\t\n98\tasync function readStdin(): Promise<string> {\n99\t  const chunks: Buffer[] = [];\n100\t  for await (const chunk of input) chunks.push(chunk as Buffer);\n101\t  return Buffer.concat(chunks).toString(\"utf8\");\n102\t}\n103\t\n104\tfunction readOptionsFrom(flags: Flags): ReadOptions {\n105\t  const opts: ReadOptions = {};\n106\t  if (!flags[\"all\"]) opts.reachableFrom = typeof flags[\"rev\"] === \"string\" ? flags[\"rev\"] : \"HEAD\";\n107\t  if (typeof flags[\"kind\"] === \"string\") opts.kind = flags[\"kind\"];\n108\t  if (typeof flags[\"source\"] === \"string\") opts.source = flags[\"source\"];\n109\t  if (typeof flags[\"conversation\"] === \"string\") opts.conversation = flags[\"conversation\"];\n110\t  return opts;\n111\t}\n112\t\n113\tfunction snippet(event: EvidenceEvent): string {\n114\t  const c = event.content as Record<string, unknown> | string | null;\n115\t  let text = \"\";\n116\t  if (typeof c === \"string\") text = c;\n117\t  else if (c && typeof c === \"object\") {\n118\t    text = String(c[\"text\"] ?? c[\"summary\"] ?? c[\"title\"] ?? JSON.stringify(c));\n119\t  }\n120\t  text = text.replace(/\\s+/g, \" \").trim();\n121\t  return text.length > 100 ? text.slice(0, 97) + \"...\" : text;\n122\t}\n123\t\n124\tfunction printHuman(events: EvidenceEvent[]): void {\n125\t  for (const e of events) {\n126\t    const conv = e.conversation ? `${e.conversation.id.slice(0, 28)}#${e.conversation.seq}` : \"-\";\n127\t    const role =\n128\t      (e.content as Record<string, unknown> | null | undefined) &&\n129\t      typeof e.content === \"object\"\n130\t        ? String((e.content as Record<string, unknown>)[\"role\"] ?? e.actor.type)\n131\t        : e.actor.type;\n132\t    process.stdout.write(\n133\t      `${e.occurred_at}  ${e.kind}  ${role.padEnd(9)}  ${conv}  ${snippet(e)}\\n`,\n134\t    );\n135\t  }\n136\t}\n137\t\n138\tfunction printJsonl(events: EvidenceEvent[], includeRaw: boolean): void {\n139\t  for (const e of events) {\n140\t    const out = includeRaw ? e : { ...e, raw: undefined };\n141\t    process.stdout.write(JSON.stringify(out) + \"\\n\");\n142\t  }\n143\t}\n144\t\n145\tasync function cmdAppend(flags: Flags): Promise<void> {\n146\t  const repo = await requireRepo();\n147\t  const body = await readStdin();\n148\t  const drafts: EventDraft[] = body\n149\t    .split(\"\\n\")\n150\t    .filter((l) => l.trim())\n151\t    .map((l) => JSON.parse(l) as EventDraft);\n152\t  if (drafts.length === 0) return;\n153\t  const result = await appendEvents(repo, drafts);\n154\t  if (!flags[\"quiet\"]) {\n155\t    for (const e of result.appended) process.stdout.write(e.id + \"\\n\");\n156\t    process.stderr.write(\n157\t      `appended ${result.appended.length}, deduped ${result.deduped}` +\n158\t        (result.anchor ? ` (anchor ${result.anchor.slice(0, 12)})` : \" (pending: no commits yet)\") +\n159\t        \"\\n\",\n160\t    );\n161\t  }\n162\t}\n163\t\n164\tasync function cmdLog(flags: Flags): Promise<void> {\n165\t  const repo = await requireRepo();\n166\t  const events = await readEvents(repo, readOptionsFrom(flags));\n167\t  if (flags[\"json\"]) printJsonl(events, false);\n168\t  else printHuman(events);\n169\t}\n170\t\n171\tasync function cmdShow(positional: string[], flags: Flags): Promise<void> {\n172\t  const prefix = positional[0];\n173\t  if (!prefix) {\n174\t    process.stderr.write(\"usage: cledger show <conversation-id-prefix>\\n\");\n175\t    process.exit(2);\n176\t  }\n177\t  const repo = await requireRepo();\n178\t  const events = await readEvents(repo, { conversation: prefix });\n179\t  if (events.length === 0) {\n180\t    process.stderr.write(`no events for conversation ${prefix}\\n`);\n181\t    process.exit(1);\n182\t  }\n183\t  if (flags[\"json\"]) {\n184\t    printJsonl(events, true);\n185\t    return;\n186\t  }\n187\t  for (const e of sortEvents(events)) {\n188\t    const c = e.content as Record<string, unknown>;\n189\t    const role = typeof c === \"object\" && c ? String(c[\"role\"] ?? e.actor.type) : e.actor.type;\n190\t    const text =\n191\t      typeof c === \"object\" && c && typeof c[\"text\"] === \"string\"\n192\t        ? (c[\"text\"] as string)\n193\t        : JSON.stringify(e.content, null, 2);\n194\t    process.stdout.write(`\\n[${e.occurred_at}] ${role} (${e.kind}, ${e.id.slice(0, 16)})\\n`);\n195\t    process.stdout.write(text.trimEnd() + \"\\n\");\n196\t  }\n197\t}\n198\t\n199\tasync function cmdConversations(flags: Flags): Promise<void> {\n200\t  const repo = await requireRepo();\n201\t  const events = await readEvents(repo, readOptionsFrom(flags));\n202\t  const byConv = new Map<string, { count: number; first: string; last: string; source: string }>();\n203\t  for (const e of events) {\n204\t    const id = e.conversation?.id ?? \"(none)\";\n205\t    const entry = byConv.get(id) ?? {\n206\t      count: 0,\n207\t      first: e.occurred_at,\n208\t      last: e.occurred_at,\n209\t      source: e.producer.source ?? e.producer.tool,\n210\t    };\n211\t    entry.count++;\n212\t    if (e.occurred_at < entry.first) entry.first = e.occurred_at;\n213\t    if (e.occurred_at > entry.last) entry.last = e.occurred_at;\n214\t    byConv.set(id, entry);\n215\t  }\n216\t  for (const [id, s] of [...byConv.entries()].sort((a, b) => a[1].last.localeCompare(b[1].last))) {\n217\t    process.stdout.write(`${id}  ${s.source}  ${s.count} events  ${s.first} .. ${s.last}\\n`);\n218\t  }\n219\t}\n220\t\n221\tasync function cmdExport(flags: Flags): Promise<void> {\n222\t  const repo = await requireRepo();\n223\t  const opts: ReadOptions = {};\n224\t  if (typeof flags[\"rev\"] === \"string\") opts.reachableFrom = flags[\"rev\"];\n225\t  const events = await readEvents(repo, opts);\n226\t  printJsonl(events, true);\n227\t}\n228\t\n229\tasync function cmdSync(flags: Flags): Promise<void> {\n230\t  const repo = await requireRepo();\n231\t  const remote = typeof flags[\"remote\"] === \"string\" ? flags[\"remote\"] : \"origin\";\n232\t  const mode = flags[\"push\"] ? \"push\" : flags[\"fetch\"] ? \"fetch\" : \"both\";\n233\t  const result = await sync(repo, remote, mode, {\n234\t    skipScan: flags[\"no-scan\"] === true,\n235\t    paranoid: flags[\"paranoid\"] === true,\n236\t  });\n237\t  process.stderr.write(\n238\t    `sync ${remote}: ${result.fetched ? \"fetched+merged\" : \"nothing fetched\"}, ` +\n239\t      `${result.pushed ? \"pushed\" : \"not pushed\"}\\n`,\n240\t  );\n241\t}\n242\t\n243\tasync function cmdTransportPush(positional: string[]): Promise<void> {\n244\t  const repo = await findRepo(process.cwd());\n245\t  if (!repo) return; // a hook must never fail the user's push\n246\t  const remote = positional[0] || \"origin\";\n247\t  try {\n248\t    await transportPush(repo, remote);\n249\t  } catch (err) {\n250\t    if (err instanceof ScanBlockedError) {\n251\t      // transport.strict: nonzero exit makes git abort the entire push.\n252\t      process.stderr.write(\"cledger: entire push blocked (transport.strict is enabled)\\n\");\n253\t      process.exit(1);\n254\t    }\n255\t    // Anything else is a cledger bug or environment problem; the user's\n256\t    // code push must proceed regardless.\n257\t    process.stderr.write(\n258\t      `cledger: transport-push error (push continues): ${err instanceof Error ? err.message : String(err)}\\n`,\n259\t    );\n260\t  }\n261\t}\n262\t\n263\tasync function cmdScan(flags: Flags): Promise<void> {\n264\t  const repo = await requireRepo();\n265\t  const tier: \"standard\" | \"paranoid\" = flags[\"paranoid\"] ? \"paranoid\" : \"standard\";\n266\t  const opts: ReadOptions = {};\n267\t  if (typeof flags[\"rev\"] === \"string\") opts.reachableFrom = flags[\"rev\"];\n268\t  const events = await readEvents(repo, opts);\n269\t  const findings = filterFindings(scanEvents(events, tier), await loadAllowlist(repo));\n270\t  if (findings.length === 0) {\n271\t    process.stderr.write(\"cledger scan: no findings\\n\");\n272\t    return;\n273\t  }\n274\t  for (const f of findings) process.stdout.write(formatFinding(f) + \"\\n\");\n275\t  process.stderr.write(`cledger scan: ${findings.length} finding(s)\\n`);\n276\t  process.exit(1);\n277\t}\n278\t\n279\tasync function cmdAllow(positional: string[]): Promise<void> {\n280\t  if (positional.length === 0) {\n281\t    process.stderr.write(\"usage: cledger allow <fingerprint...>\\n\");\n282\t    process.exit(2);\n283\t  }\n284\t  const repo = await requireRepo();\n285\t  await addToAllowlist(repo, positional);\n286\t  process.stderr.write(`allowlisted ${positional.length} fingerprint(s)\\n`);\n287\t}\n288\t\n289\tasync function cmdRedact(positional: string[], flags: Flags): Promise<void> {\n290\t  const idPrefix = positional[0];\n291\t  if (!idPrefix) {\n292\t    process.stderr.write(\"usage: cledger redact <event-id-prefix> (--pattern REGEX | --all) [--reason TEXT]\\n\");\n293\t    process.exit(2);\n294\t  }\n295\t  const repo = await requireRepo();\n296\t  const redactOpts: { pattern?: string; all?: boolean; reason?: string } = {};\n297\t  if (typeof flags[\"pattern\"] === \"string\") redactOpts.pattern = flags[\"pattern\"];\n298\t  if (flags[\"all\"] === true) redactOpts.all = true;\n299\t  if (typeof flags[\"reason\"] === \"string\") redactOpts.reason = flags[\"reason\"];\n300\t  const result = await redactEvent(repo, idPrefix, redactOpts);\n301\t  const fingerprints = result.event.redactions?.map((r) => r.fingerprint).join(\", \") || \"(none)\";\n302\t  process.stderr.write(\n303\t    `cledger red