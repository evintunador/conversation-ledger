cord<string, unknown> = {\n598\t    target: located.event.id,\n599\t    mode: hasPattern ? \"pattern\" : \"all\",\n600\t    fingerprints: newRecords.map((r) => r.fingerprint),\n601\t  };\n602\t  if (opts.reason) redactionContent.reason = opts.reason;\n603\t\n604\t  const redactionDraft: EventDraft = {\n605\t    kind: \"redaction\",\n606\t    occurred_at: new Date().toISOString(),\n607\t    actor,\n608\t    producer: { tool: \"cledger\" },\n609\t    content: redactionContent,\n610\t    links: [{ rel: \"redacts\", target: located.event.id }],\n611\t  };\n612\t  if (located.event.conversation) redactionDraft.conversation = located.event.conversation;\n613\t\n614\t  const appendResult = await appendEvents(repo, [redactionDraft]);\n615\t  const redactionEvent = appendResult.appended[0];\n616\t  if (!redactionEvent) {\n617\t    throw new Error(\"cledger redact: failed to append companion redaction event\");\n618\t  }\n619\t\n620\t  // Local purge: only meaningful when the event was already anchored (a\n621\t  // pending-queue rewrite never touched the notes ref) and only safe when\n622\t  // nobody else has a copy of the pre-redaction history yet.\n623\t  let squashed = false;\n624\t  if (located.anchor !== null) {\n625\t    const remoteHasRef = (await git([\"ls-remote\", \"origin\", NOTES_REF], {\n626\t      cwd: repo.root,\n627\t      allowFailure: true,\n628\t    })).trim();\n629\t    if (!remoteHasRef) {\n630\t      const tree = (await git([\"rev-parse\", `${NOTES_REF}^{tree}`], { cwd: repo.root })).trim();\n631\t      const squashedCommit = (\n632\t        await git([\"commit-tree\", tree, \"-m\", \"cledger: notes history squashed after redaction\"], {\n633\t          cwd: repo.root,\n634\t        })\n635\t      ).trim();\n636\t      await git([\"update-ref\", NOTES_REF, squashedCommit], { cwd: repo.root });\n637\t      squashed = true;\n638\t    } else {\n639\t      process.stderr.write(\n640\t        \"cledger redact: refs/notes/conversation-ledger already has a co