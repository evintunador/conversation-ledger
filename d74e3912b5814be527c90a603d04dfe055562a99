ble at runtime.\nimport { readFileSync, writeFileSync } from \"node:fs\";\n\nconst path =\n  \"/Users/evintunador/repos/evintunador/conversation-ledger/src/test/fixtures/secret-corpus.json\";\nconst corpus = JSON.parse(readFileSync(path, \"utf-8\"));\n\nconst out = { positives: [], negatives: corpus.negatives };\nfor (const p of corpus.positives) {\n  const { rule, secret, context } = p;\n  if (!context.includes(secret)) {\n    throw new Error(`${rule}: context does not contain its secret`);\n  }\n  const mid = Math.floor(secret.length / 2);\n  out.positives.push({\n    rule,\n    secret_parts: [secret.slice(0, mid), secret.slice(mid)],\n    context: context.split(secret).join(\"{SECRET}\"),\n  });\n}\nwriteFileSync(path, JSON.stringify(out, null, 2) + \"\\n\");\nconsole.log(`rewrote ${out.positives.length} positives`);\n// sanity: no reassembled secret remains literally in the file\nconst text = readFileSync(path, \"utf-8\");\nfor (const p of out.positives) {\n  const secret = p.secret_parts.join(\"\");\n  if (text.includes(secret)) throw new Error(`literal secret survived: ${p.rule}`);\n}\nconsole.log(\"no literal secrets remain in fixture\");\n","filePath":"/private/tmp/claude-501/-Users-evintunador-repos-evintunador-conversation-ledger/353eecbb-eaf7-4854-a575-a9d56e290707/scratchpad/split-fixture.mjs","originalFile":null,"structuredPatch":[],"type":"create","userModified":false},"type":"user","userType":"external","uuid":"19838093-291a-4acc-a57f-2378eb90d818","version":"2.1.215"},"format":"claude-code-jsonl/1"},"recorded_at":"2026-07-20T05:29:56.502Z","schema":"conversation-ledger/v1"}
