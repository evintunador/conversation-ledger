{"actor":{"type":"human"},"content":{"blocks":[{"content":"1\timport { mkdir, readFile, rm, writeFile } from \"node:fs/promises\";\n2\timport { existsSync } from \"node:fs\";\n3\timport { join } from \"node:path\";\n4\timport { canonicalJson, sha256Hex } from \"./canonical.js\";\n5\timport {\n6\t  currentBranch,\n7\t  git,\n8\t  gitUserIdentity,\n9\t  headSha,\n10\t  repoIdentity,\n11\t  revList,\n12\t  statusPorcelain,\n13\t  type RepoInfo,\n14\t} from \"./git.js\";\n15\timport {\n16\t  finalizeEvent,\n17\t  parseEventLine,\n18\t  serializeEvent,\n19\t  type Actor,\n20\t  type EventDraft,\n21\t  type EvidenceEvent,\n22\t  type RepoContext,\n23\t} from \"./schema.js\";\n24\timport { redactDraft, type RedactionRecord } from \"./redact/apply.js\";\n25\timport { captureRules, collectEnvValues, loadConfig } from \"./redact/config.js\";\n26\timport { RULESET_VERSION, type RedactionRule } from \"./redact/rules.js\";\n27\timport { filterFindings, formatFinding, loadAllowlist, scanEvents } from \"./redact/scan.js\";\n28\t\n29\texport const NOTES_NAME = \"conversation-ledger\";\n30\texport const NOTES_REF = `refs/notes/${NOTES_NAME}`;\n31\t\n32\t/**\n33\t * Storage model: one git note per anchor commit under refs/notes/\n34\t * conversation-ledger. The note body is JSONL — one canonical-JSON event\n35\t * per line, lexicographically sorted, unique. Everything lives in the note\n36\t * blob itself (no out-of-tree pointers), so records are reachable from the\n37\t * ref, GC-safe, travel with `git push`/`fetch` of that one ref, and merge\n38\t * conflict-free with the cat_sort_uniq notes strategy.\n39\t *\n40\t * Events are anchored to HEAD at capture time, so conversations ride the\n41\t * commit DAG: merge a branch and its conversations become reachable from\n42\t * the target branch with no extra machinery.\n43\t */\n44\t\n45\tfunction stateDir(repo: RepoInfo): string {\n46\t  return join(repo.gitDir, \"conversation-ledger\");\n47\t}\n48\t\n49\tfunction pendingPath(repo: RepoInfo): string {\n50\t  return join(stateDir(repo), \"pending.jsonl\");\n51\t}\n52\t\n53\t/** Local, rebuildable cache/state only — never the record of truth. */\n54\tasync function ensureStateDir(repo: RepoInfo): Promise<void> {\n55\t  await mkdir(stateDir(repo), { recursive: true });\n56\t}\n57\t\n58\texport async function ensureMergeConfig(repo: RepoInfo): Promise<void> {\n59\t  const key = `notes.${NOTES_NAME}.mergeStrategy`;\n60\t  const current = (await git([\"config\", \"--get\", key], {\n61\t    cwd: repo.root,\n62\t    allowFailure: true,\n63\t  })).trim();\n64\t  if (current !== \"cat_sort_uniq\") {\n65\t    await git([\"config\", key, \"cat_sort_uniq\"], { cwd: repo.root });\n66\t  }\n67\t}\n68\t\n69\texport async function captureContext(repo: RepoInfo): Promise<RepoContext> {\n70\t  const [identity, branch, head, status] = await Promise.all([\n71\t    repoIdentity(repo),\n72\t    currentBranch(repo),\n73\t    headSha(repo),\n74\t    statusPorcelain(repo),\n75\t  ]);\n76\t  const context: RepoContext = { repo: identity, cwd: repo.root };\n77\t  if (branch) context.branch = branch;\n78\t  if (head) context.head = head;\n79\t  if (status.trim()) context.dirty_fingerprint = sha256Hex(status);\n80\t  return context;\n81\t}\n82\t\n83\tasync function readNoteLines(repo: RepoInfo, anchor: string, refName = NOTES_NAME): Promise<string[]> {\n84\t  const body = await git([\"notes\", \"--ref\", refName, \"show\", anchor], {\n85\t    cwd: repo.root,\n86\t    allowFailure: true,\n87\t  });\n88\t  return body.split(\"\\n\").filter((l) => l.trim().length > 0);\n89\t}\n90\t\n91\t/** `refName` defaults to the main ledger ref; the scan gate also reads a temp fetched ref. */\n92\texport async function readNoteEvents(\n93\t  repo: RepoInfo,\n94\t  anchor: string,\n95\t  refName = NOTES_NAME,\n96\t): Promise<EvidenceEvent[]> {\n97\t  return (await readNoteLines(repo, anchor, refName)).map(parseEventLine);\n98\t}\n99\t\n100\t/** All (anchor commit, note) pairs in the ledger ref (or `refName`, for reading a temp fetched ref). */\n101\texport async function listAnchors(repo: RepoInfo, refName = NOTES_NAME): Promise<string[]> {\n102\t  const out = await git([\"notes\", \"--ref\", refName, \"list\"], {\n103\t    cwd: repo.root,\n104\t    allowFailure: true,\n105\t  });\n106\t  return out\n107\t    .split(\"\\n\")\n108\t    .filter(Boolean)\n109\t    .map((line) => line.split(/\\s+/)[1])\n110\t    .filter((sha): sha is string => Boolean(sha));\n111\t}\n112\t\n113\tasync function withLock<T>(repo: RepoInfo, fn: () => Promise<T>): Promise<T> {\n114\t  await ensureStateDir(repo);\n115\t  const lockDir = join(stateDir(repo), \"lock\");\n116\t  const deadline = Date.now() + 10_000;\n117\t  for (;;) {\n118\t    try {\n119\t      await mkdir(lockDir);\n120\t      break;\n121\t    } catch {\n122\t      if (Date.now() > deadline) {\n123\t        // A crashed writer can leave the lock behind; steal it after the\n124\t        // wait budget rather than wedging capture hooks forever.\n125\t        await rm(lockDir, { recursive: true, force: true });\n126\t      } else {\n127\t        await new Promise((r) => setTimeout(r, 100));\n128\t      }\n129\t    }\n130\t  }\n131\t  try {\n132\t    return await fn();\n133\t  } finally {\n134\t    await rm(lockDir, { recursive: true, force: true });\n135\t  }\n136\t}\n137\t\n138\texport interface AppendResult {\n139\t  appended: EvidenceEvent[];\n140\t  deduped: number;\n141\t  /** null when events went to the pending queue (unborn HEAD). */\n142\t  anchor: string | null;\n143\t}\n144\t\n145\texport async function appendEvents(\n146\t  repo: RepoInfo,\n147\t  drafts: EventDraft[],\n148\t  opts: { context?: RepoContext } = {},\n149\t): Promise<AppendResult> {\n150\t  const context = opts.context ?? (await captureContext(repo));\n151\t  const config = await loadConfig(repo.root);\n152\t  const rules = captureRules(config);\n153\t  const extraValues =\n154\t    rules.length > 0 && config.redact?.env === true\n155\t      ? await collectEnvValues(repo.root)\n156\t      : undefined;\n157\t  const events = drafts.map((draft) => {\n158\t    const withContext = { ...draft, context: draft.context ?? context };\n159\t    if (rules.length === 0) return finalizeEvent(withContext);\n160\t    const { draft: redacted, records } = redactDraft(withContext, {\n161\t      rules,\n162\t      ...(extraValues ? { extraValues } : {}),\n163\t    });\n164\t    return finalizeEvent(records.length > 0 ? { ...redacted, redactions: records } : redacted);\n165\t  });\n166\t  return withLock(repo, async () => {\n167\t    await ensureMergeConfig(repo);\n168\t    const anchor = await headSha(repo);\n169\t    if (!anchor) {\n170\t      return appendPending(repo, events);\n171\t    }\n172\t    const pending = await drainPending(repo);\n173\t    const existing = await readNoteLines(repo, anchor);\n174\t    const known = new Set(existing.map((l) => parseEventLine(l).id));\n175\t    const fresh = [...pending, ...events].filter((e) => {\n176\t      if (known.has(e.id)) return false;\n177\t      known.add(e.id);\n178\t      return true;\n179\t    });\n180\t    if (fresh.length === 0) {\n181\t      return { appended: [], deduped: events.length, anchor };\n182\t    }\n183\t    const lines = [...existing, ...fresh.map(serializeEvent)].sort();\n184\t    await git([\"notes\", \"--ref\", NOTES_NAME, \"add\", \"-f\", \"-F\", \"-\", anchor], {\n185\t      cwd: repo.root,\n186\t      input: lines.join(\"\\n\") + \"\\n\",\n187\t    });\n188\t    const freshIds = new Set(fresh.map((e) => e.id));\n189\t    return {\n190\t      appended: events.filter((e) => freshIds.has(e.id)),\n191\t      deduped: events.length - events.filter((e) => freshIds.has(e.id)).length,\n192\t      anchor,\n193\t    };\n194\t  });\n195\t}\n196\t\n197\tasync function appendPending(repo: RepoInfo, events: EvidenceEvent[]): Promise<AppendResult> {\n198\t  await ensureStateDir(repo);\n199\t  const path = pendingPath(repo);\n200\t  const existing = existsSync(path)\n201\t    ? (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean)\n202\t    : [];\n203\t  const known = new Set(existing.map((l) => parseEventLine(l).id));\n204\t  const fresh = events.filter((e) => !known.has(e.id));\n205\t  await writeFile(path, [...existing, ...fresh.map(serializeEvent)].join(\"\\n\") + \"\\n\");\n206\t  return { appended: fresh, deduped: events.length - fresh.length, anchor: null };\n207\t}\n208\t\n209\t/** Events held while HEAD was unborn; caller writes them into a real note. */\n210\tasync function drainPending(repo: RepoInfo): Promise<EvidenceEvent[]> {\n211\t  const path = pendingPath(repo);\n212\t  if (!existsSync(path)) return [];\n213\t  const events = (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean).map(parseEventLine);\n214\t  await rm(path, { force: true });\n215\t  return events;\n216\t}\n217\t\n218\texport async function readPending(repo: RepoInfo): Promise<EvidenceEvent[]> {\n219\t  const path = pendingPath(repo);\n220\t  if (!existsSync(path)) return [];\n221\t  return (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean).map(parseEventLine);\n222\t}\n223\t\n224\texport interface ReadOptions {\n225\t  /** Restrict to events anchored to commits reachable from this rev. */\n226\t  reachableFrom?: string;\n227\t  kind?: string;\n228\t  source?: string;\n229\t  conversation?: string;\n230\t}\n231\t\n232\texport async function readEvents(repo: RepoInfo, opts: ReadOptions = {}): Promise<EvidenceEvent[]> {\n233\t  let anchors = await listAnchors(repo);\n234\t  if (opts.reachableFrom) {\n235\t    const reachable = await revList(repo, opts.reachableFrom);\n236\t    anchors = anchors.filter((a) => reachable.has(a));\n237\t  }\n238\t  const events: EvidenceEvent[] = [];\n239\t  for (const anchor of anchors) {\n240\t    events.push(...(await readNoteEvents(repo, anchor)));\n241\t  }\n242\t  events.push(...(await readPending(repo)));\n243\t  const filtered = events.filter(\n244\t    (e) =>\n245\t      (!opts.kind || e.kind === opts.kind) &&\n246\t      (!opts.source || e.producer.source === opts.source) &&\n247\t      (!opts.conversation || e.conversation?.id === opts.conversation ||\n248\t        e.conversation?.id.startsWith(opts.conversation)),\n249\t  );\n250\t  return sortEvents(filtered);\n251\t}\n252\t\n253\t/** Stable order: conversation, then seq, then time, then id. */\n254\texport function sortEvents(events: EvidenceEvent[]): EvidenceEvent[] {\n255\t  return [...events].sort((a, b) => {\n256\t    const conv = (a.conversation?.id ?? \"\").localeCompare(b.conversation?.id ?? \"\");\n257\t    if (conv !== 0) return conv;\n258\t    const seq = (a.conversation?.seq ?? 0) - (b.conversation?.seq ?? 0);\n259\t    if (seq !== 0) return seq;\n260\t    const time = a.occurred_at.localeCompare(b.occurred_at);\n261\t    if (time !== 0) return time;\n262\t    return a.id.localeCompare(b.id);\n263\t  });\n264\t}\n265\t\n266\texport interface SyncResult {\n267\t  fetched: boolean;\n268\t  pushed: boolean;\n269\t}\n270\t\n271\t/**\n272\t * Event ids the remote's notes ref already has, fetched into a throwaway\n273\t * temp ref that is deleted before returning. Null means the remote has no\n274\t * ledger ref at all (e.g. first push), in which case the caller should\n275\t * treat everything local as unshared.\n276\t */\n277\tasync function remoteNoteIds(repo: RepoInfo, remote: string): Promise<Set<string> | null> {\n278\t  const remoteHasRef = (await git([\"ls-remote\", remote, NOTES_REF], {\n279\t    cwd: repo.root,\n280\t    allowFailure: true,\n281\t  })).trim();\n282\t  if (!remoteHasRef) return null;\n283\t\n284\t  const tmpName = \"conversation-ledger-scan-tmp\";\n285\t  const tmpRef = `refs/notes/${tmpName}`;\n286\t  await git([\"fetch\", remote, `+${NOTES_REF}:${tmpRef}`], { cwd: repo.root, allowFailure: true });\n287\t  try {\n288\t    const ids = new Set<string>();\n289\t    for (const anchor of await listAnchors(repo, tmpName)) {\n290\t      for (const event of await readNoteEvents(repo, anchor, tmpName)) ids.add(event.id);\n291\t    }\n292\t    return ids;\n293\t  } finally {\n294\t    await git([\"update-ref\", \"-d\", tmpRef], { cwd: repo.root, allowFailure: true });\n295\t  }\n296\t}\n297\t\n298\t/**\n299\t * Layer E: before push, scan only the events the remote does not yet have\n300\t * (already-pushed events are not rescanned every time). On any surviving\n301\t * finding, print a report and throw so sync() does not proceed to push —\n302\t * the fetch/merge phase, if it already ran, is left in place.\n303\t */\n304\tasync function runScanGate(repo: RepoInfo, remote: string, tier: \"standard\" | \"paranoid\"): Promise<void> {\n305\t  const remoteIds = await remoteNoteIds(repo, remote);\n306\t\n307\t  const localEvents: EvidenceEvent[] = [];\n308\t  for (const anchor of await listAnchors(repo)) {\n309\t    localEvents.push(...(await readNoteEvents(repo, anchor)));\n310\t  }\n311\t  localEvents.push(...(await readPending(repo)));\n312\t\n313\t  const candidates = remoteIds ? localEvents.filter((e) => !remoteIds.has(e.id)) : localEvents;\n314\t  if (candidates.length === 0) return;\n315\t\n316\t  const findings = filterFindings(scanEvents(candidates, tier), await loadAllowlist(repo));\n317\t  if (findings.length === 0) return;\n318\t\n319\t  process.stderr.write(\n320\t    `cledger sync: blocked — ${findings.length} potential secret(s) in event(s) not yet on ${remote}\\n\\n`,\n321\t  );\n322\t  for (const f of findings) process.stderr.write(`  ${formatFinding(f)}\\n`);\n323\t  process.stderr.write(\n324\t    \"\\nRemediate, then re-run sync:\\n\" +\n325\t      \"  cledger redact <event-id>     rewrite the event and remove the secret\\n\" +\n326\t      \"  cledger allow <fingerprint>   mark a fingerprint as a known false positive\\n\" +\n327\t      \"  cledger sync --no-scan        skip this gate for this sync only\\n\",\n328\t  );\n329\t  throw new Error(\n330\t    `cledger sync: push blocked — ${findings.length} potential secret(s) found (see report above)`,\n331\t  );\n332\t}\n333\t\n334\t/** Explicit, opt-in sync of the single ledger ref. Never runs implicitly. */\n335\texport async function sync(\n336\t  repo: RepoInfo,\n337\t  remote = \"origin\",\n338\t  mode: \"both\" | \"push\" | \"fetch\" = \"both\",\n339\t  opts: { skipScan?: boolean; paranoid?: boolean } = {},\n340\t): Promise<SyncResult> {\n341\t  const result: SyncResult = { fetched: false, pushed: false };\n342\t  await ensureMergeConfig(repo);\n343\t  if (mode !== \"push\") {\n344\t    const incoming = \"refs/notes/conversation-ledger-incoming\";\n345\t    const fetched = await git(\n346\t      [\"fetch\", remote, `+${NOTES_REF}:${incoming}`],\n347\t      { cwd: repo.root, allowFailure: true },\n348\t    );\n349\t    void fetched;\n350\t    const hasIncoming = (await git([\"rev-parse\", \"--verify\", \"--quiet\", incoming], {\n351\t      cwd: repo.root,\n352\t      allowFailure: true,\n353\t    })).trim();\n354\t    if (hasIncoming) {\n355\t      await git(\n356\t        [\"notes\", \"--ref\", NOTES_NAME, \"merge\", \"-s\", \"cat_sort_uniq\", incoming],\n357\t        { cwd: repo.root },\n358\t      );\n359\t      await git([\"update-ref\", \"-d\", incoming], { cwd: repo.root, allowFailure: true });\n360\t      result.fetched = true;\n361\t    }\n362\t  }\n363\t  if (mode !== \"fetch\") {\n364\t    const config = await loadConfig(repo.root);\n365\t    const scanDisabled = opts.skipScan === true || config.scan?.tier === \"off\";\n366\t    if (!scanDisabled) {\n367\t      const tier: \"standard\" | \"paranoid\" =\n368\t        opts.paranoid === true || config.scan?.tier === \"paranoid\" ? \"paranoid\" : \"standard\";\n369\t      await runScanGate(repo, remote, tier);\n370\t    }\n371\t    await git([\"push\", remote, `${NOTES_REF}:${NOTES_REF}`], { cwd: repo.root });\n372\t    result.pushed = true;\n373\t  }\n374\t  return result;\n375\t}\n376\t\n377\tinterface LocatedEvent {\n378\t  event: EvidenceEvent;\n379\t  /** Anchor commit holding the note line, or null when the event is still in pending.jsonl. */\n380\t  anchor: string | null;\n381\t  /** Full line array of the containing note (or of pending.jsonl), for in-place rewrite. */\n382\t  lines: string[];\n383\t  index: number;\n384\t}\n385\t\n386\tfunction idMatchesPrefix(id: string, prefix: string): boolean {\n387\t  if (id.startsWith(prefix)) return true;\n388\t  const hash = id.startsWith(\"ev1-\") ? id.slice(4) : id;\n389\t  return hash.startsWith(prefix);\n390\t}\n391\t\n392\t/** Find the one event matching `idPrefix` across every anchor and the pending queue. */\n393\tasync function locateEvent(repo: RepoInfo, idPrefix: string): Promise<LocatedEvent> {\n394\t  const matches: LocatedEvent[] = [];\n395\t\n396\t  for (const anchor of await listAnchors(repo)) {\n397\t    const lines = await readNoteLines(repo, anchor);\n398\t    lines.forEach((line, index) => {\n399\t      const event = parseEventLine(line);\n400\t      if (idMatchesPrefix(event.id, idPrefix)) matches.push({ event, anchor, lines, index });\n401\t    });\n402\t  }\n403\t\n404\t  const pendingFile = pendingPath(repo);\n405\t  const pendingLines = existsSync(pendingFile)\n406\t    ? (await readFile(pendingFile, \"utf8\")).split(\"\\n\").filter((l) => l.trim().length > 0)\n407\t    : [];\n408\t  pendingLines.forEach((line, index) => {\n409\t    const event = parseEventLine(line);\n410\t    if (idMatchesPrefix(event.id, idPrefix)) matches.push({ event, anchor: null, lines: pendingLines, index });\n411\t  });\n412\t\n413\t  if (matches.length === 0) {\n414\t    throw new Error(`cledger redact: no event matches id prefix \"${idPrefix}\"`);\n415\t  }\n416\t  if (matches.length > 1) {\n417\t    throw new Error(\n418\t      `cledger redact: id prefix \"${idPrefix}\" is ambiguous (${matches.length} matches: ` +\n419\t        `${matches.map((m) => m.event.id).join(\", \")})`,\n420\t    );\n421\t  }\n422\t  return matches[0]!;\n423\t}\n424\t\n425\texport interface RedactResult {\n426\t  /** The rewritten event, with the secret removed. */\n427\t  event: EvidenceEvent;\n428\t  /** The companion `redaction` event recording why `event`'s content no longer matches its id. */\n429\t  redactionEvent: EvidenceEvent;\n430\t  /** True when the pre-redaction notes history was squashed away locally (see below). */\n431\t  squashed: boolean;\n432\t}\n433\t\n434\t/**\n435\t * Human redaction of an *existing* event (layer E's remediation path, as\n436\t * opposed to capture-time redaction in redact/apply.ts). Locates the event\n437\t * by id prefix, rewrites its content in place, appends a companion\n438\t * `redaction` event, and — when the pre-redaction content was never\n439\t * pushed — squashes the local notes ref history so the old blob becomes\n440\t * unreachable.\n441\t */\n442\texport async function redactEvent(\n443\t  repo: RepoInfo,\n444\t  idPrefix: string,\n445\t  opts: { pattern?: string; all?: boolean; reason?: string },\n446\t): Promise<RedactResult> {\n447\t  const hasPattern = typeof opts.pattern === \"string\" && opts.pattern.length > 0;\n448\t  const hasAll = opts.all === true;\n449\t  if (hasPattern === hasAll) {\n450\t    throw new Error(\"cledger redact: exactly one of --pattern or --all is required\");\n451\t  }\n452\t\n453\t  const { located, rewritten, newRecords } = await withLock(repo, async () => {\n454\t    const located = await locateEvent(repo, idPrefix);\n455\t    const original = located.event;\n456\t\n457\t    let rewrittenContent: unknown = original.content;\n458\t    let rewrittenRaw = original.raw;\n459\t    const newRecords: RedactionRecord[] = [];\n460\t\n461\t    if (hasPattern) {\n462\t      let pattern: RegExp;\n463\t      try {\n464\t        pattern = new RegExp(opts.pattern!, \"g\");\n465\t      } catch (err) {\n466\t        throw new Error(\n467\t          `cledger redact: invalid --pattern regex: ${err instanceof Error ? err.message : String(err)}`,\n468\t        );\n469\t      }\n470\t      const rule: RedactionRule = {\n471\t        id: \"manual\",\n472\t        tier: \"capture\",\n473\t        description: \"Manually specified redaction pattern\",\n474\t        pattern,\n475\t      };\n476\t      const { draft: patched, records } = redactDraft(original, { rules: [rule] });\n477\t      if (records.length === 0) {\n478\t        throw new Error(`cledger redact: --pattern matched nothing in event ${original.id}`);\n479\t      }\n480\t      rewrittenContent = patched.content;\n481\t      rewrittenRaw = patched.raw;\n482\t      newRecords.push(...records);\n483\t    } else {\n484\t      const fingerprint = sha256Hex(canonicalJson(original.content)).slice(0, 12);\n485\t      rewrittenContent = `[REDACTED:manual:${fingerprint}]`;\n486\t      rewrittenRaw = undefined;\n487\t      newRecords.push({ rule: \"manual\", ruleset: RULESET_VERSION, fingerprint, path: \"content\" });\n488\t    }\n489\t\n490\t    // CRITICAL: this draft carries `original.id` explicitly, and\n491\t    // finalizeEvent below (`draft.id ?? eventId(draft)`) preserves a\n492\t    // supplied id rather than recomputing it. If the id were recomputed\n493\t    // here from the rewritten (secret-free) content, it would no longer\n494\t    // match the id a fresh capture of the *original* source material would\n495\t    // produce — so a later transcript rescan (ids are a pure function of\n496\t    // source content; that's what makes capture idempotent) would\n497\t    // regenerate the original, unredacted event under its old id, dedup\n498\t    // would no longer recognize it as \"already seen\" against this\n499\t    // rewritten line, and the secret would silently reappear in the\n500\t    // ledger. Keeping the id stable means the rewritten line permanently\n501\t    // occupies that id slot — any rescan producing the same id dedups\n502\t    // against it instead. The companion `redaction` event appended below\n503\t    // is what records why this event's content no longer matches what i