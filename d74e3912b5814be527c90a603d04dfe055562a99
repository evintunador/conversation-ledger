{"actor":{"type":"human"},"content":{"blocks":[{"content":"1\t/**\n2\t * Shared test utilities. Not a test file itself (no top-level `test()`\n3\t * calls), safe to import from any *.test.ts file. All git repos it creates\n4\t * live under a fresh mkdtemp() directory and MUST be cleaned up by the\n5\t * caller (see cleanupRepo/cleanupDir) — tests must never touch this\n6\t * project's own repo.\n7\t */\n8\timport { mkdtemp, rm } from \"node:fs/promises\";\n9\timport { tmpdir } from \"node:os\";\n10\timport { join } from \"node:path\";\n11\timport { git, findRepo, type RepoInfo } from \"../git.js\";\n12\timport { finalizeEvent, type EventDraft, type EvidenceEvent } from \"../schema.js\";\n13\t\n14\t/** Create a fresh repo under the OS temp dir, with local git identity set. */\n15\texport async function makeTempRepo(prefix = \"cledger-test-\"): Promise<RepoInfo> {\n16\t  const dir = await mkdtemp(join(tmpdir(), prefix));\n17\t  await git([\"init\", \"-q\", \"-b\", \"main\"], { cwd: dir });\n18\t  await git([\"config\", \"user.email\", \"test@example.com\"], { cwd: dir });\n19\t  await git([\"config\", \"user.name\", \"Test User\"], { cwd: dir });\n20\t  await git([\"config\", \"commit.gpgsign\", \"false\"], { cwd: dir });\n21\t  const repo = await findRepo(dir);\n22\t  if (!repo) throw new Error(\"failed to initialize temp repo\");\n23\t  return repo;\n24\t}\n25\t\n26\t/** Create a bare repo under the OS temp dir, for use as a sync remote. */\n27\texport async function makeBareRepo(prefix = \"cledger-remote-\"): Promise<string> {\n28\t  const dir = await mkdtemp(join(tmpdir(), prefix));\n29\t  await git([\"init\", \"-q\", \"--bare\", \"-b\", \"main\"], { cwd: dir });\n30\t  return dir;\n31\t}\n32\t\n33\t/** Recursively remove a temp repo/dir. Safe no-op if already gone. */\n34\texport async function cleanupDir(dir: string): Promise<void> {\n35\t  await rm(dir, { recursive: true, force: true });\n36\t}\n37\t\n38\texport async function cleanupRepo(repo: RepoInfo): Promi