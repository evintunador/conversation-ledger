{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\timport { canonicalJson, sha256Hex } from \"./canonical.js\";\n2\timport type { RedactionRecord } from \"./redact/apply.js\";\n3\t\n4\texport const SCHEMA_VERSION = \"conversation-ledger/v1\";\n5\t\n6\t/**\n7\t * The six well-known event kinds. `kind` is an open string so downstream\n8\t * tools can extend the ledger without a schema release; unknown kinds are\n9\t * stored verbatim. The ledger never interprets content, whatever the kind.\n10\t */\n11\texport const KNOWN_KINDS = [\n12\t  \"conversation_turn\",\n13\t  \"decision\",\n14\t  \"document\",\n15\t  \"annotation\",\n16\t  \"redaction\",\n17\t  \"supersession\",\n18\t] as const;\n19\t\n20\texport interface Actor {\n21\t  /** \"human\" | \"agent\" | \"system\" */\n22\t  type: string;\n23\t  /** Stable identity when known, e.g. git author email or model id. */\n24\t  id?: string;\n25\t  display?: string;\n26\t}\n27\t\n28\texport interface Producer {\n29\t  /** Capture tool that wrote this event, e.g. \"cledger\". */\n30\t  tool: string;\n31\t  /** Capture tool version. Not part of event identity. */\n32\t  version?: string;\n33\t  /** Source system the content came from, e.g. \"claude-code\", \"codex\". */\n34\t  source?: string;\n35\t  /** Source system's native session identifier. */\n36\t  session_id?: string;\n37\t}\n38\t\n39\texport interface RepoContext {\n40\t  /** Best-known repository identity (origin URL or top-level dir name). */\n41\t  repo?: string;\n42\t  branch?: string;\n43\t  /** HEAD commit SHA at capture time. */\n44\t  head?: string;\n45\t  /** Working directory the conversation ran in. */\n46\t  cwd?: string;\n47\t  /** sha256 of `git status --porcelain` output when the tree was dirty. */\n48\t  dirty_fingerprint?: string;\n49\t}\n50\t\n51\texport interface ConversationRef {\n52\t  /** Namespaced conversation id, e.g. \"claude-code:<session uuid>\". */\n53\t  id: string;\n54\t  /** Stable ordering key within the conversation (source line index). */\n55\t  seq: number;\n56\t}\n57\t\n58\texport interface EventLink {\n59\t  /** e.g. \"redacts\", \"supersedes\", \"annotates\", \"replies_to\" */\n60\t  rel: string;\n61\t  /** Target event id. */\n62\t  target: string;\n63\t}\n64\t\n65\texport interface EvidenceEvent {\n66\t  /** \"ev1-\" + sha256 of the identity subset (see eventId). */\n67\t  id: string;\n68\t  schema: typeof SCHEMA_VERSION;\n69\t  kind: string;\n70\t  /** When the content happened, ISO 8601 UTC (from the source when known). */\n71\t  occurred_at: string;\n72\t  /** When this event was appended to the ledger. Not part of identity. */\n73\t  recorded_at: string;\n74\t  actor: Actor;\n75\t  producer: Producer;\n76\t  /** IANA media type of `content`; defaults to application/json. */\n77\t  media_type?: string;\n78\t  /** The visible content itself, stored inline and never reinterpreted. */\n79\t  content: unknown;\n80\t  /** Repository context at capture time. Not part of identity. */\n81\t  context?: RepoContext;\n82\t  conversation?: ConversationRef;\n83\t  links?: EventLink[];\n84\t  /**\n85\t   * Opaque source-native payload for lossless export, e.g. the original\n86\t   * transcript line(s). Versioned by `format`. Not part of identity.\n87\t   */\n88\t  raw?: { format: string; data: unknown };\n89\t  /**\n90\t   * Capture-time redaction records (rule id, ruleset version, fingerprint,\n91\t   * location path), present when the capture-tier ruleset rewrote part of\n92\t   * `content`/`raw.data` before this event was finalized. Deliberately\n93\t   * excluded from the identity subset: the rewritten `content` already\n94\t   * determines `id`, so including this here would double-count the same\n95\t   * fact and would churn ids on ruleset upgrades even when the visible\n96\t   * content is unchanged.\n97\t   */\n98\t  redactions?: RedactionRecord[];\n99\t}\n100\t\n101\t/** Fields an adapter supplies; id/schema/recorded_at are filled at append. */\n102\texport type EventDraft = Omit<EvidenceEvent, \"id\" | \"schema\" | \"recorded_at\"> &\n103\t  Partial<Pick<EvidenceEvent, \"id\" | \"schema\" | \"recorded_at\">>;\n104\t\n105\t/**\n106\t * Event identity is derived from the durable, source-determined subset so\n107\t * that re-scanning the same source material always yields the same id\n108\t * (idempotent capture). Volatile provenance — recorded_at, context, raw,\n109\t * producer.version/tool — is deliberately excluded: a re-ingestion under a\n110\t * different HEAD or adapter version must dedup, not duplicate.\n111\t */\n112\texport function eventId(event: EventDraft): string {\n113\t  const identity = {\n114\t    schema: SCHEMA_VERSION,\n115\t    kind: event.kind,\n116\t    occurred_at: event.occurred_at,\n117\t    actor: { type: event.actor.type, id: event.actor.id },\n118\t    source: event.producer.source,\n119\t    session_id: event.producer.session_id,\n120\t    conversation: event.conversation,\n121\t    media_type: event.media_type,\n122\t    content: event.content,\n123\t    links: event.links,\n124\t  };\n125\t  return \"ev1-\" + sha256Hex(canonicalJson(identity));\n126\t}\n127\t\n128\texport function finalizeEvent(draft: EventDraft, now = new Date()): EvidenceEvent {\n129\t  const event: EvidenceEvent = {\n130\t    ...draft,\n131\t    id: draft.id ?? eventId(draft),\n132\t    schema: SCHEMA_VERSION,\n133\t    recorded_at: draft.recorded_at ?? now.toISOString(),\n134\t  };\n135\t  const problems = validateEvent(event);\n136\t  if (problems.length > 0) {\n137\t    throw new Error(`invalid event: ${problems.join(\"; \")}`);\n138\t  }\n139\t  return event;\n140\t}\n141\t\n142\texport function validateEvent(event: EvidenceEvent): string[] {\n143\t  const problems: string[] = [];\n144\t  if (!event.id?.startsWith(\"ev1-\")) problems.push(\"id must start with ev1-\");\n145\t  if (event.schema !== SCHEMA_VERSION) problems.push(`schema must be ${SCHEMA_VERSION}`);\n146\t  if (!event.