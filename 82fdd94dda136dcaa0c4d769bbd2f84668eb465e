{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\t/**\n2\t * Shared test utilities. Not a test file itself (no top-level `test()`\n3\t * calls), safe to import from any *.test.ts file. All git repos it creates\n4\t * live under a fresh mkdtemp() directory and MUST be cleaned up by the\n5\t * caller (see cleanupRepo/cleanupDir) — tests must never touch this\n6\t * project's own repo.\n7\t */\n8\timport { mkdtemp, rm } from \"node:fs/promises\";\n9\timport { tmpdir } from \"node:os\";\n10\timport { join } from \"node:path\";\n11\timport { git, findRepo, type RepoInfo } from \"../git.js\";\n12\timport { finalizeEvent, type EventDraft, type EvidenceEvent } from \"../schema.js\";\n13\t\n14\t/** Create a fresh repo under the OS temp dir, with local git identity set. */\n15\texport async function makeTempRepo(prefix = \"cledger-test-\"): Promise<RepoInfo> {\n16\t  const dir = await mkdtemp(join(tmpdir(), prefix));\n17\t  await git([\"init\", \"-q\", \"-b\", \"main\"], { cwd: dir });\n18\t  await git([\"config\", \"user.email\", \"test@example.com\"], { cwd: dir });\n19\t  await git([\"config\", \"user.name\", \"Test User\"], { cwd: dir });\n20\t  await git([\"config\", \"commit.gpgsign\", \"false\"], { cwd: dir });\n21\t  const repo = await findRepo(dir);\n22\t  if (!repo) throw new Error(\"failed to initialize temp repo\");\n23\t  return repo;\n24\t}\n25\t\n26\t/** Create a bare repo under the OS temp dir, for use as a sync remote. */\n27\texport async function makeBareRepo(prefix = \"cledger-remote-\"): Promise<string> {\n28\t  const dir = await mkdtemp(join(tmpdir(), prefix));\n29\t  await git([\"init\", \"-q\", \"--bare\", \"-b\", \"main\"], { cwd: dir });\n30\t  return dir;\n31\t}\n32\t\n33\t/** Recursively remove a temp repo/dir. Safe no-op if already gone. */\n34\texport async function cleanupDir(dir: string): Promise<void> {\n35\t  await rm(dir, { recursive: true, force: true });\n36\t}\n37\t\n38\texport async function cleanupRepo(repo: RepoInfo): Promise<void> {\n39\t  await cleanupDir(repo.root);\n40\t}\n41\t\n42\t/** Create a commit (empty by default) and return its SHA. */\n43\texport async function makeCommit(repo: RepoInfo, message = \"commit\"): Promise<string> {\n44\t  await git([\"commit\", \"--allow-empty\", \"-q\", \"-m\", message], { cwd: repo.root });\n45\t  return (await git([\"rev-parse\", \"HEAD\"], { cwd: repo.root })).trim();\n46\t}\n47\t\n48\t/** Build a minimal, valid EventDraft with sensible defaults, override at will. */\n49\texport function draft(overrides: Partial<EventDraft> = {}): EventDraft {\n50\t  const base: EventDraft = {\n51\t    kind: \"conversation_turn\",\n52\t    occurred_at: \"2026-01-01T00:00:00.000Z\",\n53\t    actor: { type: \"human\" },\n54\t    producer: { tool: \"cledger\" },\n55\t    content: { text: \"hello\" },\n56\t  };\n57\t  return { ...base, ...overrides };\n58\t}\n59\t\n60\t/** Build a fully finalized event from overrides (id/schema/recorded_at auto-filled). */\n61\texport function event(overrides: Partial<EventDraft> = {}, now?: Date): EvidenceEvent {\n62\t  return finalizeEvent(draft(overrides), now);\n63\t}\n64\t","tool_use_id":"toolu_01RxUbBZGB3ovq1pGfoB2biH","type":"tool_result"}],"role":"user"},"context":{"branch":"main","cwd":"/Users/evintunador/repos/evintunador/conversation-ledger","dirty_fingerprint":"db9dee3b20ece4c8d09a3feb50ecf84b70c566c31b152350e8bd060a46d4b1d3","head":"82fdd94dda136dcaa0c4d769bbd2f84668eb465e","repo":"git@github.com:evintunador/conversation-ledger.git"},"conversation":{"id":"claude-code:1adc3903-054a-4c3f-b176-50dc694bfab9","seq":191},"id":"ev1-9eac08ffb5b751e3bc26f371beeb8a4333ca4554fbfbf331d3d229e7de5febe7","kind":"conversation_turn","occurred_at":"2026-07-20T16:35:41.935Z","producer":{"session_id":"1adc3903-054a-4c3f-b176-50dc694bfab9","source":"claude-code","tool":"cledger","version":"0.5.0"},"raw":{"data":{"cwd":"/Users/evintunador/repos/evintunador/conversation-ledger","ent