{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\t/**\n2\t * Format-drift detection shared by adapters. Adapters are tolerant parsers\n3\t * that skip line types they don't recognize; that handles additive upstream\n4\t * changes gracefully, but a genuinely new message type would otherwise be\n5\t * dropped in silence (raw included). Counting the unrecognized types and\n6\t * warning is the drift tripwire — captured events are unaffected.\n7\t */\n8\t\n9\texport interface CaptureResult {\n10\t  appended: number;\n11\t  deduped: number;\n12\t  /** Skipped-line tallies keyed by unrecognized type, e.g. {\"response_item/agent_message\": 3}. */\n13\t  unrecognized: Record<string, number>;\n14\t}\n15\t\n16\texport function countUnrecognized(unrecognized: Record<string, number>, key: string): void {\n17\t  unrecognized[key] = (unrecognized[key] ?? 0) + 1;\n18\t}\n19\t\n20\texport function warnUnrecognized(source: string, unrecognized: Record<string, number>): void {\n21\t  const entries = Object.entries(unrecognized);\n22\t  if (entries.length === 0) return;\n23\t  const total = entries.reduce((n, [, c]) => n + c, 0);\n24\t  const detail = entries\n25\t    .sort((a, b) => b[1] - a[1])\n26\t    .map(([type, count]) => `${type} x${count}`)\n27\t    .join(\", \");\n28\t  process.stderr.write(\n29\t    `cledger: ${source} skipped ${total} transcript line(s) of unrecognized type (${detail}) — ` +\n30\t      `the ${source} format may have added content this cledger version does not capture; ` +\n31\t      `update conversation-ledger or report it\\n`,\n32\t  );\n33\t}\n34\t","tool_use_id":"toolu_011crfyth9JVpzjN27ueFYjE","type":"tool_result"}],"role":"user"},"context":{"branch":"main","cwd":"/Users/evintunador/repos/evintunador/conversation-ledger","dirty_fingerprint":"db9dee3b20ece4c8d09a3feb50ecf84b70c566c31b152350e8bd060a46d4b1d3","head":"82fdd94dda136dcaa0c4d769bbd2f84668eb465e","repo":"git@github.com:evintunad