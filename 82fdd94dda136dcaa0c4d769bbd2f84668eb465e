{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"141\texport async function appendEvents(\n142\t  repo: RepoInfo,\n143\t  drafts: EventDraft[],\n144\t  opts: { context?: RepoContext } = {},\n145\t): Promise<AppendResult> {\n146\t  const context = opts.context ?? (await captureContext(repo));\n147\t  const config = await loadConfig(repo.root);\n148\t  // First capture in a repo wires up transport (pre-push hook + fetch\n149\t  // refspec); later calls are cheap re-checks. Never throws.\n150\t  await ensureTransport(repo, config);\n151\t  const rules = captureRules(config);\n152\t  const extraValues =\n153\t    rules.length > 0 && config.redact?.env === true\n154\t      ? await collectEnvValues(repo.root)\n155\t      : undefined;\n156\t  const events = drafts.map((draft) => {\n157\t    const withContext = { ...draft, context: draft.context ?? context };\n158\t    if (rules.length === 0) return finalizeEvent(withContext);\n159\t    const { draft: redacted, records } = redactDraft(withContext, {\n160\t      rules,\n161\t      ...(extraValues ? { extraValues } : {}),\n162\t    });\n163\t    return finalizeEvent(records.length > 0 ? { ...redacted, redactions: records } : redacted);\n164\t  });\n165\t  return withLock(repo, async () => {\n166\t    await ensureMergeConfig(repo);\n167\t    const anchor = await headSha(repo);\n168\t    if (!anchor) {\n169\t      return appendPending(repo, events);\n170\t    }\n171\t    const pending = await drainPending(repo);\n172\t    const existing = await readNoteLines(repo, anchor);\n173\t    const known = new Set(existing.map((l) => parseEventLine(l).id));\n174\t    const fresh = [...pending, ...events].filter((e) => {\n175\t      if (known.has(e.id)) return false;\n176\t      known.add(e.id);\n177\t      return true;\n178\t    });\n179\t    if (fresh.length === 0) {\n180\t      return { appended: [], deduped: events.length, anchor };\n181\t    }\n182\t    const lines = [..