{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\timport { readFileSync } from \"node:fs\";\n2\timport { mkdir, readFile, stat, writeFile } from \"node:fs/promises\";\n3\timport { basename, join } from \"node:path\";\n4\timport { findRepo, gitUserIdentity, type GitUserIdentity, type RepoInfo } from \"../git.js\";\n5\timport { appendEvents } from \"../store.js\";\n6\timport type { Actor, EventDraft } from \"../schema.js\";\n7\timport { countUnrecognized, warnUnrecognized, type CaptureResult } from \"./drift.js\";\n8\t\n9\t/** Codex CLI hooks-engine payload (subset we read). */\n10\tinterface CodexHookPayload {\n11\t  session_id?: string;\n12\t  transcript_path?: string;\n13\t  cwd?: string;\n14\t  hook_event_name?: string;\n15\t  turn_id?: string;\n16\t}\n17\t\n18\t/** One line of a `~/.codex/sessions/YYYY/MM/DD/rollout-*.jsonl` file. */\n19\tinterface CodexRolloutLine {\n20\t  type?: string;\n21\t  timestamp?: string;\n22\t  payload?: Record<string, unknown>;\n23\t}\n24\t\n25\tconst CONVERTIBLE_RESPONSE_TYPES = new Set([\n26\t  \"message\",\n27\t  \"function_call\",\n28\t  \"function_call_output\",\n29\t  \"custom_tool_call\",\n30\t  \"custom_tool_call_output\",\n31\t  \"agent_message\",\n32\t]);\n33\t\n34\t/**\n35\t * Line types we deliberately do not capture: session/turn bookkeeping and\n36\t * the event_msg UI stream (whose conversation content duplicates\n37\t * response_item lines). Anything else is unrecognized — likely new upstream\n38\t * content — and counted for the drift warning; same for response_item\n39\t * payload types outside CONVERTIBLE_RESPONSE_TYPES (except reasoning,\n40\t * which is encrypted/opaque and skipped by policy).\n41\t */\n42\tconst KNOWN_SKIPPED_LINE_TYPES = new Set([\n43\t  \"session_meta\",\n44\t  \"turn_context\",\n45\t  \"compacted\",\n46\t  \"event_msg\",\n47\t  \"world_state\",\n48\t  \"inter_agent_communication_metadata\",\n49\t]);\n50\t\n51\tconst KNOWN_SKIPPE