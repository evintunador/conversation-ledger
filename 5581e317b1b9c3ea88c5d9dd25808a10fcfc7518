o: RepoInfo, refName = NOTES_NAME): Promise<string[]> {\n99\t  const out = await git([\"notes\", \"--ref\", refName, \"list\"], {\n100\t    cwd: repo.root,\n101\t    allowFailure: true,\n102\t  });\n103\t  return out\n104\t    .split(\"\\n\")\n105\t    .filter(Boolean)\n106\t    .map((line) => line.split(/\\s+/)[1])\n107\t    .filter((sha): sha is string => Boolean(sha));\n108\t}\n109\t\n110\tasync function withLock<T>(repo: RepoInfo, fn: () => Promise<T>): Promise<T> {\n111\t  await ensureStateDir(repo);\n112\t  const lockDir = join(stateDir(repo), \"lock\");\n113\t  const deadline = Date.now() + 10_000;\n114\t  for (;;) {\n115\t    try {\n116\t      await mkdir(lockDir);\n117\t      break;\n118\t    } catch {\n119\t      if (Date.now() > deadline) {\n120\t        // A crashed writer can leave the lock behind; steal it after the\n121\t        // wait budget rather than wedging capture hooks forever.\n122\t        await rm(lockDir, { recursive: true, force: true });\n123\t      } else {\n124\t        await new Promise((r) => setTimeout(r, 100));\n125\t      }\n126\t    }\n127\t  }\n128\t  try {\n129\t    return await fn();\n130\t  } finally {\n131\t    await rm(lockDir, { recursive: true, force: true });\n132\t  }\n133\t}\n134\t\n135\texport interface AppendResult {\n136\t  appended: EvidenceEvent[];\n137\t  deduped: number;\n138\t  /** null when events went to the pending queue (unborn HEAD). */\n139\t  anchor: string | null;\n140\t}\n141\t\n142\texport async function appendEvents(\n143\t  repo: RepoInfo,\n144\t  drafts: EventDraft[],\n145\t  opts: { context?: RepoContext } = {},\n146\t): Promise<AppendResult> {\n147\t  const context = opts.context ?? (await captureContext(repo));\n148\t  const config = await loadConfig(repo.root);\n149\t  // First capture in a repo wires up transport (pre-push hook + fetch\n150\t  // refspec); later calls are cheap re-checks. Never throws.\n151\t  await ensureTransport(repo, config);\n152\t  const rules = captureRules(config);\n153\t  // Exact-value scrubbing layers, each tagged with its own rule id for the\n154\t  // audit trail. Only consulted when capture redaction is active at all\n155\t  // (rules.length > 0); known-secrets additionally requires its opt-in flag.\n156\t  const extraValues: ExtraValueGroup[] = [];\n157\t  if (rules.length > 0) {\n158\t    if (config.redact?.knownSecrets === true) {\n159\t      const known = await loadKnownSecrets(repo);\n160\t      if (known.length > 0) extraValues.push({ ruleId: \"known-secret\", values: known });\n161\t    }\n162\t    if (config.redact?.env === true) {\n163\t      const env = await collectEnvValues(repo.root);\n164\t      if (env.length > 0) extraValues.push({ ruleId: \"env-value\", values: env });\n165\t    }\n166\t  }\n167\t  const events = drafts.map((draft) => {\n168\t    const withContext = { ...draft, context: draft.context ?? context };\n169\t    if (rules.length === 0) return finalizeEvent(withContext);\n170\t    const { draft: redacted, records } = redactDraft(withContext, {\n171\t      rules,\n172\t      ...(extraValues.length > 0 ? { extraValues } : {}),\n173\t    });\n174\t    return finalizeEvent(records.length > 0 ? { ...redacted, redactions: records } : redacted);\n175\t  });\n176\t  return withLock(repo, async () => {\n177\t    await ensureMergeConfig(repo);\n178\t    const anchor = await headSha(repo);\n179\t    if (!anchor) {\n180\t      return appendPending(repo, events);\n181\t    }\n182\t    const pending = await drainPending(repo);\n183\t    const existing = await readNoteLines(repo, anchor);\n184\t    const known = new Set(existing.map((l) => parseEventLine(l).id));\n185\t    const fresh = [...pending, ...events].filter((e) => {\n186\t      if (known.has(e.id)) return false;\n187\t      known.add(e.id);\n188\t      return true;\n189\t    });\n190\t    if (fresh.length === 0) {\n191\t      return { appended: [], deduped: events.length, anchor };\n192\t    }\n193\t    const lines = [...existing, ...fresh.map(serializeEvent)].sort();\n194\t    await git([\"notes\", \"--ref\", NOTES_NAME, \"add\", \"-f\", \"-F\", \"-\", anchor], {\n195\t      cwd: repo.root,\n196\t      input: lines.join(\"\\n\") + \"\\n\",\n197\t    });\n198\t    const freshIds = new Set(fresh.map((e) => e.id));\n199\t    return {\n200\t      appended: events.filter((e) => freshIds.has(e.id)),\n201\t      deduped: events.length - events.filter((e) => freshIds.has(e.id)).length,\n202\t      anchor,\n203\t    };\n204\t  });\n205\t}\n206\t\n207\tasync function appendPending(repo: RepoInfo, events: EvidenceEvent[]): Promise<AppendResult> {\n208\t  await ensureStateDir(repo);\n209\t  const path = pendingPath(repo);\n210\t  const existing = existsSync(path)\n211\t    ? (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean)\n212\t    : [];\n213\t  const known = new Set(existing.map((l) => parseEventLine(l).id));\n214\t  const fresh = events.filter((e) => !known.has(e.id));\n215\t  await writeFile(path, [...existing, ...fresh.map(serializeEvent)].join(\"\\n\") + \"\\n\");\n216\t  return { appended: fresh, deduped: events.length - fresh.length, anchor: null };\n217\t}\n218\t\n219\t/** Events held while HEAD was unborn; caller writes them into a real note. */\n220\tasync function drainPending(repo: RepoInfo): Promise<EvidenceEvent[]> {\n221\t  const path = pendingPath(repo);\n222\t  if (!existsSync(path)) return [];\n223\t  const events = (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean).map(parseEventLine);\n224\t  await rm(path, { force: true });\n225\t  return events;\n226\t}\n227\t\n228\texport async function readPending(repo: RepoInfo): Promise<EvidenceEvent[]> {\n229\t  const path = pendingPath(repo);\n230\t  if (!existsSync(path)) return [];\n231\t  return (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean).map(parseEventLine);\n232\t}\n233\t\n234\texport interface ReadOptions {\n235\t  /** Restrict to events anchored to commits reachable from this rev. */\n236\t  reachableFrom?: string;\n237\t  kind?: string;\n238\t  source?: string;\n239\t  conversation?: string;\n240\t}\n241\t\n242\texport async function readEvents(repo: RepoInfo, opts: ReadOptions = {}): Promise<EvidenceEvent[]> {\n243\t  // Lazy transport: fold in anything a plain `git fetch`/`git pull` staged.\n244\t  await absorbIncoming(repo);\n245\t  let anchors = await listAnchors(repo);\n246\t  if (opts.reachableFrom) {\n247\t    const reachable = await revList(repo, opts.reachableFrom);\n248\t    anchors = anchors.filter((a) => reachable.has(a));\n249\t  }\n250\t  const events: EvidenceEvent[] = [];\n251\t  for (const anchor of anchors) {\n252\t    events.push(...(await readNoteEvents(repo, anchor)));\n253\t  }\n254\t  events.push(...(await readPending(repo)));\n255\t  const filtered = events.filter(\n256\t    (e) =>\n257\t      (!opts.kind || e.kind === opts.kind) &&\n258\t      (!opts.source || e.producer.source === opts.source) &&\n259\t      (!opts.conversation || e.conversation?.id === opts.conversation ||\n260\t        e.conversation?.id.startsWith(opts.conversation)),\n261\t  );\n262\t  return sortEvents(filtered);\n263\t}\n264\t\n265\t/** Stable order: conversation, then seq, then time, then id. */\n266\texport function sortEvents(events: EvidenceEvent[]): EvidenceEvent[] {\n267\t  return [...events].sort((a, b) => {\n268\t    const conv = (a.conversation?.id ?? \"\").localeCompare(b.conversation?.id ?? \"\");\n269\t    if (conv !== 0) return conv;\n270\t    const seq = (a.conversation?.seq ?? 0) - (b.conversation?.seq ?? 0);\n271\t    if (seq !== 0) return seq;\n272\t    const time = a.occurred_at.localeCompare(b.occurred_at);\n273\t    if (time !== 0) return time;\n274\t    return a.id.localeCompare(b.id);\n275\t  });\n276\t}\n277\t\n278\texport interface SyncResult {\n279\t  fetched: boolean;\n280\t  pushed: boolean;\n281\t}\n282\t\n283\t/**\n284\t * Event ids the remote's notes ref already has, fetched into a throwaway\n285\t * temp ref that is deleted before returning. Null means the remote has no\n286\t * ledger ref at all (e.g. first push), in which case the caller should\n287\t * treat everything local as unshared.\n288\t */\n289\tasync function remoteNoteIds(repo: RepoInfo, remote: string): Promise<Set<string> | null> {\n290\t  const remoteHasRef = (await git([\"ls-remote\", remote, NOTES_REF], {\n291\t    cwd: repo.root,\n292\t    allowFailure: true,\n293\t  })).trim();\n294\t  if (!remoteHasRef) return null;\n295\t\n296\t  const tmpName = \"conversation-ledger-scan-tmp\";\n297\t  const tmpRef = `refs/notes/${tmpName}`;\n298\t  await git([\"fetch\", remote, `+${NOTES_REF}:${tmpRef}`], { cwd: repo.root, allowFailure: true });\n299\t  try {\n300\t    const ids = new Set<string>();\n301\t    for (const anchor of await listAnchors(repo, tmpName)) {\n302\t      for (const event of await readNoteEvents(repo, anchor, tmpName)) ids.add(event.id);\n303\t    }\n304\t    return ids;\n305\t  } finally {\n306\t    await git([\"update-ref\", \"-d\", tmpRef], { cwd: repo.root, allowFailure: true });\n307\t  }\n308\t}\n309\t\n310\t/** Thrown when the layer-E scan gate blocks a push; carries no secrets. */\n311\texport class ScanBlockedError extends Error {\n312\t  constructor(public readonly findings: number) {\n313\t    super(`cledger sync: push blocked — ${findings} potential secret(s) found (see report above)`);\n314\t  }\n315\t}\n316\t\n317\t/**\n318\t * Layer E: before push, scan only the events the remote does not yet have\n319\t * (already-pushed events are not rescanned every time). On any surviving\n320\t * finding, print a report and throw so sync() does not proceed to push —\n321\t * the fetch/merge phase, if it already ran, is left in place.\n322\t */\n323\tasync function runScanGate(repo: RepoInfo, remote: string, tier: \"standard\" | \"paranoid\"): Promise<void> {\n324\t  const remoteIds = await remoteNoteIds(repo, remote);\n325\t\n326\t  const localEvents: EvidenceEvent[] = [];\n327\t  for (const anchor of await listAnchors(repo)) {\n328\t    localEvents.push(...(await readNoteEvents(repo, anchor)));\n329\t  }\n330\t  localEvents.push(...(await readPending(repo)));\n331\t\n332\t  const candidates = remoteIds ? localEvents.filter((e) => !remoteIds.has(e.id)) : localEvents;\n333\t  if (candidates.length === 0) return;\n334\t\n335\t  const findings = filterFindings(scanEvents(candidates, tier), await loadAllowlist(repo));\n336\t  if (findings.length === 0) return;\n337\t\n338\t  process.stderr.write(\n339\t    `cledger sync: blocked — ${findings.length} potential secret(s) in event(s) not yet on ${remote}\\n\\n`,\n340\t  );\n341\t  for (const f of findings) process.stderr.write(`  ${formatFinding(f)}\\n`);\n342\t  process.stderr.write(\n343\t    \"\\nRemediate, then re-run sync:\\n\" +\n344\t      \"  cledger redact <event-id>     rewrite the event and remove the secret\\n\" +\n345\t      \"  cledger allow <fingerprint>   mark a fingerprint as a known false positive\\n\" +\n346\t      \"  cledger sync --no-scan        skip this gate for this sync only\\n\",\n347\t  );\n348\t  throw new ScanBlockedError(findings.length);\n349\t}\n350\t\n351\t/**\n352\t * Sync of the single ledger ref: explicit via `cledger sync`, or run by the\n353\t * pre-push transport hook (see transportPush). The fetch phase stages into\n354\t * INCOMING_REF and absorbs it — the same path a plain `git fetch` plus a\n355\t * later read takes.\n356\t */\n357\texport async function sync(\n358\t  repo: RepoInfo,\n359\t  remote = \"origin\",\n360\t  mode: \"both\" | \"push\" | \"fetch\" = \"both\",\n361\t  opts: { skipScan?: boolean; paranoid?: boolean } = {},\n362\t): Promise<SyncResult> {\n363\t  const result: SyncResult = { fetched: false, pushed: false };\n364\t  await ensureMergeConfig(repo);\n365\t  if (mode !== \"push\") {\n366\t    await git(\n367\t      [\"fetch\", remote, `+${NOTES_REF}:${INCOMING_REF}`],\n368\t      { cwd: repo.root, allowFailure: true },\n369\t    );\n370\t    result.fetched = await absorbIncoming(repo);\n371\t  }\n372\t  if (mode !== \"fetch\") {\n373\t    const config = await loadConfig(repo.root);\n374\t    const scanDisabled = opts.skipScan === true || config.scan?.tier === \"off\";\n375\t    if (!scanDisabled) {\n376\t      const tier: \"standard\" | \"paranoid\" =\n377\t        opts.paranoid === true || config.scan?.tier === \"paranoid\" ? \"paranoid\" : \"standard\";\n378\t      await runScanGate(repo, remote, tier);\n379\t    }\n380\t    // The pushed child git inherits CLEDGER_INTERNAL, telling the pre-push\n381\t    // transport hook this push *is* the ledger push — no recursion.\n382\t    const prior = process.env[\"CLEDGER_INTERNAL\"];\n383\t    process.env[\"CLEDGER_INTERNAL\"] = \"1\";\n384\t    try {\n385\t      await git([\"push\", remote, `${NOTES_REF}:${NOTES_REF}`], { cwd: repo.root });\n386\t    } finally {\n387\t      if (prior === undefined) delete process.env[\"CLEDGER_INTERNAL\"];\n388\t      else process.env[\"CLEDGER_INTERNAL\"] = prior;\n389\t    }\n390\t    result.pushed = true;\n391\t  }\n392\t  return result;\n393\t}\n394\t\n395\texport interface TransportPushResult {\n396\t  pushed: boolean;\n397\t  /** True when scan findings held the ledger back (non-strict mode). */\n398\t  held: boolean;\n399\t}\n400\t\n401\t/**\n402\t * Pre-push hook entrypoint policy. Pushes the ledger ref alongside the\n403\t * user's own push. A scan finding blocks only the ledger by default —\n404\t * secrets never leave the machine, but a false positive never blocks\n405\t * shipping code; {\"transport\": {\"strict\": true}} escalates to aborting the\n406\t * whole push (rethrows ScanBlockedError; the CLI exits nonzero). Any other\n407\t * failure (network, missing remote ref perms) warns and lets the push\n408\t * proceed — the hook must never make `git push` flaky.\n409\t */\n410\texport async function transportPush(repo: RepoInfo, remote: string): Promise<TransportPushResult> {\n411\t  const config = await loadConfig(repo.root);\n412\t  if (config.transport?.hook === false) return { pushed: false, held: false };\n413\t  const hasNotes = (await git([\"rev-parse\", \"--verify\", \"--quiet\", NOTES_REF], {\n414\t    cwd: repo.root,\n415\t    allowFailure: true,\n416\t  })).trim();\n417\t  if (!hasNotes) return { pushed: false, held: false };\n418\t\n419\t  try {\n420\t    await sync(repo, remote, \"push\");\n421\t    return { pushed: true, held: false };\n422\t  } catch (err) {\n423\t    if (err instanceof ScanBlockedError) {\n424\t      if (config.transport?.strict === true) throw err;\n425\t      process.stderr.write(\n426\t        \"cledger: conversation records were held back from this push (potential secrets — \" +\n427\t          \"see report above); your code push continues. Run `cledger sync` to review and \" +\n428\t          \"remediate.\\n\",\n429\t      );\n430\t      return { pushed: false, held: true };\n431\t    }\n432\t    process.stderr.write(\n433\t      `cledger: ledger push skipped (${err instanceof Error ? err.message : String(err)})\\n`,\n434\t    );\n435\t    return { pushed: false, held: false };\n436\t  }\n437\t}\n438\t\n439\tinterface LocatedEvent {\n440\t  event: EvidenceEvent;\n441\t  /** Anchor commit holding the note line, or null when the event is still in pending.jsonl. */\n442\t  anchor: string | null;\n443\t  /** Full line array of the containing note (or of pending.jsonl), for in-place rewrite. */\n444\t  lines: string[];\n445\t  index: number;\n446\t}\n447\t\n448\tfunction idMatchesPrefix(id: string, prefix: string): boolean {\n449\t  if (id.startsWith(prefix)) return true;\n450\t  const hash = id.startsWith(\"ev1-\") ? id.slice(4) : id;\n451\t  return hash.startsWith(prefix);\n452\t}\n453\t\n454\t/** Find the one event matching `idPrefix` across every anchor and the pending queue. */\n455\tasync function locateEvent(repo: RepoInfo, idPrefix: string): Promise<LocatedEvent> {\n456\t  const matches: LocatedEvent[] = [];\n457\t\n458\t  for (const anchor of await listAnchors(repo)) {\n459\t    const lines = await readNoteLines(repo, anchor);\n460\t    lines.forEach((line, index) => {\n461\t      const event = parseEventLine(line);\n462\t      if (idMatchesPrefix(event.id, idPrefix)) matches.push({ event, anchor, lines, index });\n463\t    });\n464\t  }\n465\t\n466\t  const pendingFile = pendingPath(repo);\n467\t  const pendingLines = existsSync(pendingFile)\n468\t    ? (await readFile(pendingFile, \"utf8\")).split(\"\\n\").filter((l) => l.trim().length > 0)\n469\t    : [];\n470\t  pendingLines.forEach((line, index) => {\n471\t    const event = parseEventLine(line);\n472\t    if (idMatchesPrefix(event.id, idPrefix)) matches.push({ event, anchor: null, lines: pendingLines, index });\n473\t  });\n474\t\n475\t  if (matches.length === 0) {\n476\t    throw new Error(`cledger redact: no event matches id prefix \"${idPrefix}\"`);\n477\t  }\n478\t  if (matches.length > 1) {\n479\t    throw new Error(\n480\t      `cledger redact: id prefix \"${idPrefix}\" is ambiguous (${matches.length} matches: ` +\n481\t        `${matches.map((m) => m.event.id).join(\", \")})`,\n482\t    );\n483\t  }\n484\t  return matches[0]!;\n485\t}\n486\t\n487\texport interface RedactResult {\n488\t  /** The rewritten event, with the secret removed. */\n489\t  event: EvidenceEvent;\n490\t  /** The companion `redaction` event recording why `event`'s content no longer matches its id. */\n491\t  redactionEvent: EvidenceEvent;\n492\t  /** True when the pre-redaction notes history was squashed away locally (see below). */\n493\t  squashed: boolean;\n494\t  /**\n495\t   * Count of newly-remembered secret values written to the opt-in\n496\t   * known-secrets store (0 unless `redact.knownSecrets` is on and this was a\n497\t   * `--pattern` redaction that matched at least one not-already-known value).\n498\t   */\n499\t  knownSecretsRemembered: number;\n500\t}\n501\t\n502\t/**\n503\t * Human redaction of an *existing* event (layer E's remediation path, as\n504\t * opposed to capture-time redaction in redact/apply.ts). Locates the event\n505\t * by id prefix, rewrites its content in place, appends a companion\n506\t * `redaction` event, and — when the pre-redaction content was never\n507\t * pushed — squashes the local notes ref history so the old blob becomes\n508\t * unreachable.\n509\t */\n510\texport async function redactEvent(\n511\t  repo: RepoInfo,\n512\t  idPrefix: string,\n513\t  opts: { pattern?: string; all?: boolean; reason?: string },\n514\t): Promise<RedactResult> {\n515\t  const hasPattern = typeof opts.pattern === \"string\" && opts.pattern.length > 0;\n516\t  const hasAll = opts.all === true;\n517\t  if (hasPattern === hasAll) {\n518\t    throw new Error(\"cledger redact: exactly one of --pattern or --all is required\");\n519\t  }\n520\t\n521\t  // Opt-in: when on, remember the exact values a --pattern redaction scrubs so\n522\t  // capture-time redaction can keep them out of future events (see\n523\t  // redact/known-secrets.ts). The --all path blanks whole content, so there is\n524\t  // no reusable value to remember there.\n525\t  const config = await loadConfig(repo.root);\n526\t  const rememberSecrets = hasPattern && config.redact?.knownSecrets === true;\n527\t\n528\t  const { located, rewritten, newRecords, secretValues } = await withLock(repo, async () => {\n529\t    const located = await locateEvent(repo, idPrefix);\n530\t    const original = located.event;\n531\t\n532\t    let rewrittenContent: unknown = original.content;\n533\t    let rewrittenRaw = original.raw;\n534\t    const newRecords: RedactionRecord[] = [];\n535\t    const secretValues: string[] = [];\n536\t\n537\t    if (hasPattern) {\n538\t      let pattern: RegExp;\n539\t      try {\n540\t        pattern = new RegExp(opts.pattern!, \"g\");\n541\t      } catch (err) {\n542\t        throw new Error(\n543\t          `cledger redact: invalid --pattern regex: ${err instanceof Error ? err.message : String(err)}`,\n544\t        );\n545\t      }\n546\t      const rule: RedactionRule = {\n547\t        id: \"manual\",\n548\t        tier: \"capture\",\n549\t        description: \"Manually specified redaction pattern\",\n550\t        pattern,\n551\t      };\n552\t      const { draft: patched, records } = redactDraft(original, { rules: [rule] });\n553\t      if (records.length === 0) {\n554\t        throw new Error(`cledger redact: --pattern matched nothing in event ${original.id}`);\n555\t      }\n556\t      rewrittenContent = patched.content;\n557\t      rewrittenRaw = patched.raw;\n558\t      newRecords.push(...records);\n559\t      if (rememberSecrets) {\n560\t        secretValues.push(...collectMatches(original.content, pattern));\n561\t        if (original.raw) secretValues.push(...collectMatches(original.raw.data, pattern));\n562\t      }\n563\t    } else {\n564\t      const fingerprint = sha256Hex(canonicalJson(original.content)).slice(0, 12);\n565\t      rewrittenContent = `[REDACTED:manual:${fingerprint}]`;\n566\t      rewrittenRaw = undefined;\n567\t      newRecords.push({ rule: \"manual\", ruleset: RULESET_VERSION, fingerprint, path: \"content\" });\n568\t    }\n569\t\n570\t    // CRITICAL: this draft carries `original.id` explicitly, and\n571\t    // finalizeEvent below (`draft.id ?? eventId(draft)`) preserves a\n572\t    // supplied id rather than recomputing it. If the id were recomputed\n573\t    // here from the rewritten (secret-free) content, it would no longer\n574\t    // match the id a fresh capture of the *original* source material would\n575\t    // produce — so a later transcript rescan (ids are a pure function of\n576\t    // source content; that's what makes capture idempotent) would\n577\t    // regenerate the original, unredacted event under its old id, dedup\n578\t    // would no longer recognize it as \"already seen\" against this\n579\t    // rewritten line, and the secret would silently reappear in the\n580\t    // ledger. Keeping the id stable means the rewritten line permanently\n581\t    // occupies that id slot — any rescan producing the same id dedups\n582\t    // against it instead. The companion `redaction` event appended below\n583\t    // is what records why this event's content no longer matches what its\n584\t    // id would normally imply.\n585\t    const rewrittenDraft: EventDraft = {\n586\t      ...original,\n587\t      id: original.id,\n588\t      content: rewrittenContent,\n589\t      redactions: [...(original.redactions ?? []), ...newRecords],\n590\t    };\n591\t    if (rewrittenRaw === undefined) delete rewrittenDraft.raw;\n592\t    else rewrittenDraft.raw = rewrittenRaw;\n593\t\n594\t    const rewritten = finalizeEvent(rewrittenDraft);\n595\t    if (rewritten.id !== original.id) {\n596\t      // Should be unreachable given the explicit `id: original.id` above;\n597\t      // guarded because a dedup break here is exactly the failure mode the\n598\t      // comment above exists to prevent.\n599\t      throw new Error(\"cledger redact: internal error — rewritten event id drifted from the original\");\n600\t    }\n601\t\n602\t    const newLines = [...located.lines];\n603\t    newLines[located.index] = serializeEvent(rewritten);\n604\t    if (located.anchor !== null) {\n605\t      newLines.sort();\n606\t      await git([\"notes\", \"--ref\", NOTES_NAME, \"add\", \"-f\", \"-F\", \"-\", located.anchor], {\n607\t        cwd: repo.root,\n608\t        input: newLines.join(\"\\n\") + \"\\n\",\n609\t      });\n610\t    } else {\n611\t      await ensureStateDir(repo);\n612\t      await writeFile(pendingPath(repo), newLines.join(\"\\n\") + \"\\n\");\n613\t    }\n614\t\n615\t    return { located, rewritten, newRecords, secretValues };\n616\t  });\n617\t\n618\t  // Persist remembered secret values outside the notes lock (the store is its\n619\t  // own file under .git/, unrelated to the notes ref). addKnownSecrets applies\n620\t  // the min-length filter and dedups, returning how many were newly stored.\n621\t  let knownSecretsRemembered = 0;\n622\t  if (rem