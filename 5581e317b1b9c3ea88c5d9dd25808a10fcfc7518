{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\t/**\n2\t * Shared test utilities. Not a test file itself (no top-level `test()`\n3\t * calls), safe to import from any *.test.ts file. All git repos it creates\n4\t * live under a fresh mkdtemp() directory and MUST be cleaned up by the\n5\t * caller (see cleanupRepo/cleanupDir) — tests must never touch this\n6\t * project's own repo.\n7\t */\n8\timport { mkdtempSync, rmSync } from \"node:fs\";\n9\timport { mkdtemp, rm } from \"node:fs/promises\";\n10\timport { tmpdir } from \"node:os\";\n11\timport { join } from \"node:path\";\n12\timport { git, findRepo, type RepoInfo } from \"../git.js\";\n13\timport { finalizeEvent, type EventDraft, type EvidenceEvent } from \"../schema.js\";\n14\t\n15\t/**\n16\t * Isolate every test process from the developer's real home directory.\n17\t *\n18\t * loadConfig() reads user-level config at `~/.config/cledger/config.json` via\n19\t * os.homedir() (which honors $HOME on POSIX), so a developer who has, say,\n20\t * `redact.knownSecrets` enabled globally would silently change test behavior\n21\t * — tests asserting *default* behavior would exercise an opt-in layer and\n22\t * fail, and worse, tests could pass or fail depending on whose machine ran\n23\t * them. The node test runner gives each test *file* its own process, so\n24\t * setting HOME at module load is safe and scoped to that file.\n25\t */\n26\tconst ISOLATED_HOME = mkdtempSync(join(tmpdir(), \"cledger-test-home-\"));\n27\tprocess.env.HOME = ISOLATED_HOME;\n28\tprocess.on(\"exit\", () => {\n29\t  try {\n30\t    rmSync(ISOLATED_HOME, { recursive: true, force: true });\n31\t  } catch {\n32\t    /* best effort */\n33\t  }\n34\t});\n35\t\n36\t/** Create a fresh repo under the OS temp dir, with local git identity set. */\n37\texport async function makeTempRepo(prefix = \"cledger-test-\"): Promise<RepoInfo> {\n38\t  const dir = await mkdtemp(join(tmpdir(), prefix));\n39\t  await git([\"init\", \"-q\", \"-b\", \"main\"], { cwd: dir });\n40\t  await git([\"config\", \"user.email\", \"test@example.com\"], { cwd: dir });\n41\t  await git([\"config\", \"user.name\", \"Test User\"], { cwd: dir });\n42\t  await git([\"config\", \"commit.gpgsign\", \"false\"], { cwd: dir });\n43\t  const repo = await findRepo(dir);\n44\t  if (!repo) throw new Error(\"failed to initialize temp repo\");\n45\t  return repo;\n46\t}\n47\t\n48\t/** Create a bare repo under the OS temp dir, for use as a sync remote. */\n49\texport async function makeBareRepo(prefix = \"cledger-remote-\"): Promise<string> {\n50\t  const dir = await mkdtemp(join(tmpdir(), prefix));\n51\t  await git([\"init\", \"-q\", \"--bare\", \"-b\", \"main\"], { cwd: dir });\n52\t  return dir;\n53\t}\n54\t\n55\t/** Recursively remove a temp repo/dir. Safe no-op if already gone. */\n56\texport async function cleanupDir(dir: string): Promise<void> {\n57\t  await rm(dir, { recursive: true, force: true });\n58\t}\n59\t\n60\texport async function cleanupRepo(repo: RepoInfo): Promise<void> {\n61\t  await cleanupDir(repo.root);\n62\t}\n63\t\n64\t/** Create a commit (empty by default) and return its SHA. */\n65\texport async function makeCommit(repo: RepoInfo, message = \"commit\"): Promise<string> {\n66\t  await git([\"commit\", \"--allow-empty\", \"-q\", \"-m\", message], { cwd: repo.root });\n67\t  return (await git([\"rev-parse\", \"HEAD\"], { cwd: repo.root })).trim();\n68\t}\n69\t\n70\t/** Build a minimal, valid EventDraft with sensible defaults, override at will. */\n71\texport function draft(overrides: Partial<EventDraft> = {}): EventDraft {\n72\t  const base: EventDraft = {\n73\t    kind: \"conversation_turn\",\n74\t    occurred_at: \"2026-01-01T00:00:00.000Z\",\n75\t    actor: { type: \"human\" },\n76\t    producer: { tool: \"cledger\" },\n77\t    content: { text: \"hello\" },\n78\t  };\n79\t  return { ...base, ...overrides };\n80\t}\n81\t\n82\t/** Build a fully finalized event from overrides (id/schema/recorded_at auto-filled). */\n83\texport function event(overrides: Partial<EventDraft> = {}, now?: Date): EvidenceEvent {\n84\t  return finalizeEvent(draft(overrides), now);\n85\t}\n86\t","tool_use_id":"toolu_01VDZWrLziUuTt9hmmJHwZNv","type":"tool_result"}],"role":"user"},"context":{"branch":"main","cwd":"/Users/evintunador/repos/evintunador/conversation-ledger","head":"5581e317b1b9c3ea88c5d9dd25808a10fcfc7518","repo":"git@github.com:evintunador/conversation-ledger.git"},"conversation":{"id":"claude-code:4c1ed024-2edf-45b6-8cbb-ee40a5ebadc3","seq":139},"id":"ev1-95277182928db7f254cf1dcc1705f00b896aeaf1487778f2aff3813896181372","kind":"conversation_turn","occurred_at":"2026-07-21T06:21:51.946Z","producer":{"session_id":"4c1ed024-2edf-45b6-8cbb-ee40a5ebadc3","source":"claude-code","tool":"cledger","version":"0.8.0"},"raw":{"data":{"cwd":"/Users/evintunador/repos/evintunador/conversation-ledger","entrypoint":"cli","gitBranch":"main","isSidechain":false,"message":{"content":[{"content":"1\t/**\n2\t * Shared test utilities. Not a test file itself (no top-level `test()`\n3\t * calls), safe to import from any *.test.ts file. All git repos it creates\n4\t * live under a fresh mkdtemp() directory and MUST be cleaned up by the\n5\t * caller (see cleanupRepo/cleanupDir) — tests must never touch this\n6\t * project's own repo.\n7\t */\n8\timport { mkdtempSync, rmSync } from \"node:fs\";\n9\timport { mkdtemp, rm } from \"node:fs/promises\";\n10\timport { tmpdir } from \"node:os\";\n11\timport { join } from \"node:path\";\n12\timport { git, findRepo, type RepoInfo } from \"../git.js\";\n13\timport { finalizeEvent, type EventDraft, type EvidenceEvent } from \"../schema.js\";\n14\t\n15\t/**\n16\t * Isolate every test process from the developer's real home directory.\n17\t *\n18\t * loadConfig() reads user-level config at `~/.config/cledger/config.json` via\n19\t * os.homedir() (which honors $HOME on POSIX), so a developer who has, say,\n20\t * `redact.knownSecrets` 