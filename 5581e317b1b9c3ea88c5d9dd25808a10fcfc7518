1\timport { mkdir, readFile, rm, writeFile } from \"node:fs/promises\";\n2\timport { existsSync } from \"node:fs\";\n3\timport { join } from \"node:path\";\n4\timport { canonicalJson, sha256Hex } from \"./canonical.js\";\n5\timport {\n6\t  currentBranch,\n7\t  git,\n8\t  gitUserIdentity,\n9\t  headSha,\n10\t  repoIdentity,\n11\t  revList,\n12\t  statusPorcelain,\n13\t  type RepoInfo,\n14\t} from \"./git.js\";\n15\timport {\n16\t  absorbIncoming,\n17\t  ensureMergeConfig,\n18\t  ensureTransport,\n19\t  INCOMING_REF,\n20\t  NOTES_NAME,\n21\t  NOTES_REF,\n22\t} from \"./transport.js\";\n23\timport {\n24\t  finalizeEvent,\n25\t  parseEventLine,\n26\t  serializeEvent,\n27\t  type Actor,\n28\t  type EventDraft,\n29\t  type EvidenceEvent,\n30\t  type RepoContext,\n31\t} from \"./schema.js\";\n32\timport { collectMatches, redactDraft, type ExtraValueGroup, type RedactionRecord } from \"./redact/apply.js\";\n33\timport { captureRules, collectEnvValues, loadConfig } from \"./redact/config.js\";\n34\timport { addKnownSecrets, loadKnownSecrets } from \"./redact/known-secrets.js\";\n35\timport { RULESET_VERSION, type RedactionRule } from \"./redact/rules.js\";\n36\timport { filterFindings, formatFinding, loadAllowlist, scanEvents } from \"./redact/scan.js\";\n37\t\n38\texport { ensureMergeConfig, NOTES_NAME, NOTES_REF } from \"./transport.js\";\n39\t\n40\t/**\n41\t * Storage model: one git note per anchor commit under refs/notes/\n42\t * conversation-ledger. The note body is JSONL — one canonical-JSON event\n43\t * per line, lexicographically sorted, unique. Everything lives in the note\n44\t * blob itself (no out-of-tree pointers), so records are reachable from the\n45\t * ref, GC-safe, travel with `git push`/`fetch` of that one ref, and merge\n46\t * conflict-free with the cat_sort_uniq notes strategy.\n47\t *\n48\t * Events are anchored to HEAD at capture time, so conversations ride the\n49\t * commit DAG: merge a branch and its conversations become reachable from\n50\t * the target branch with no extra machinery.\n51\t */\n52\t\n53\tfunction stateDir(repo: RepoInfo): string {\n54\t  return join(repo.gitDir, \"conversation-ledger\");\n55\t}\n56\t\n57\tfunction pendingPath(repo: RepoInfo): string {\n58\t  return join(stateDir(repo), \"pending.jsonl\");\n59\t}\n60\t\n61\t/** Local, rebuildable cache/state only — never the record of truth. */\n62\tasync function ensureStateDir(repo: RepoInfo): Promise<void> {\n63\t  await mkdir(stateDir(repo), { recursive: true });\n64\t}\n65\t\n66\texport async function captureContext(repo: RepoInfo): Promise<RepoContext> {\n67\t  const [identity, branch, head, status] = await Promise.all([\n68\t    repoIdentity(repo),\n69\t    currentBranch(repo),\n70\t    headSha(repo),\n71\t    statusPorcelain(repo),\n72\t  ]);\n73\t  const context: RepoContext = { repo: identity, cwd: repo.root };\n74\t  if (branch) context.branch = branch;\n75\t  if (head) context.head = head;\n76\t  if (status.trim()) context.dirty_fingerprint = sha256Hex(status);\n77\t  return context;\n78\t}\n79\t\n80\tasync function readNoteLines(repo: RepoInfo, anchor: string, refName = NOTES_NAME): Promise<string[]> {\n81\t  const body = await git([\"notes\", \"--ref\", refName, \"show\", anchor], {\n82\t    cwd: repo.root,\n83\t    allowFailure: true,\n84\t  });\n85\t  return body.split(\"\\n\").filter((l) => l.trim().length > 0);\n86\t}\n87\t\n88\t/** `refName` defaults to the main ledger ref; the scan gate also reads a temp fetched ref. */\n89\texport async function readNoteEvents(\n90\t  repo: RepoInfo,\n91\t  anchor: string,\n92\t  refName = NOTES_NAME,\n93\t): Promise<EvidenceEvent[]> {\n94\t  return (await readNoteLines(repo, anchor, refName)).map(parseEventLine);\n95\t}\n96\t\n97\t/** All (anchor commit, note) pairs in the ledger ref (or `refName`, for reading a temp fetched ref). */\n98\texport async function listAnchors(repo: RepoInfo, refName = NOTES_NAME): Promise<string[]> {\n99\t  const out = await git([\"notes\", \"--ref\", refName, \"list\"], {\n100\t    cwd: repo.root,\n101\t    allowFailure: true,\n102\t  });\n103\t  return out\n104\t    .split(\"\\n\")\n105\t    .filter(Boolean)\n106\t    .map((line) => line.split(/\\s+/)[1])\n107\t    .filter((sha): sha is string => Boolean(sha));\n108\t}\n109\t\n110\tasync function withLock<T>(repo: RepoInfo, fn: () => Promise<T>): Promise<T> {\n111\t  await ensureStateDir(repo);\n112\t  const lockDir = join(stateDir(repo), \"lock\");\n113\t  const deadline = Date.now() + 10_000;\n114\t  for (;;) {\n115\t    try {\n116\t      await mkdir(lockDir);\n117\t      break;\n118\t    } catch {\n119\t      if (Date.now() > deadline) {\n120\t        // A crashed writer can leave the lock behind; steal it after the\n121\t        // wait budget rather than wedging capture hooks forever.\n122\t        await rm(lockDir, { recursive: true, force: true });\n123\t      } else {\n124\t        await new Promise((r) => setTimeout(r, 100));\n125\t      }\n126\t    }\n127\t  }\n128\t  try {\n129\t    return await fn();\n130\t  } finally {\n131\t    await rm(lockDir, { recursive: true, force: true });\n132\t  }\n133\t}\n134\t\n135\texport interface AppendResult {\n136\t  appended: EvidenceEvent[];\n137\t  deduped: number;\n138\t  /** null when events went to the pending queue (unborn HEAD). */\n139\t  anchor: string | null;\n140\t}\n141\t\n142\texport async function appendEvents(\n143\t  repo: RepoInfo,\n144\t  drafts: EventDraft[],\n145\t  opts: { context?: RepoContext } = {},\n146\t): Promise<AppendResult> {\n147\t  const context = opts.context ?? (await captureContext(repo));\n148\t  const config = await loadConfig(repo.root);\n149\t  // First capture in a repo wires up transport (pre-push hook + fetch\n150\t  // refspec); later calls are cheap re-checks. Never throws.\n151\t  await ensureTransport(repo, config);\n152\t  const rules = captureRules(config);\n153\t  // Exact-value scrubbing layers, each tagged with its own rule id for the\n154\t  // audit trail. Only consu