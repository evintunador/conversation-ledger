self for when this installation moves.\n44\t */\n45\tfunction cledgerInvocation(): { node: string; cli: string } {\n46\t  return {\n47\t    node: process.execPath,\n48\t    cli: fileURLToPath(new URL(\"./cli.js\", import.meta.url)),\n49\t  };\n50\t}\n51\t\n52\tfunction hookBlock(): string {\n53\t  const { node, cli } = cledgerInvocation();\n54\t  return [\n55\t    `# >>> ${HOOK_MARKER} (added by cledger) >>>`,\n56\t    `# Shares this repo's conversation records (${NOTES_REF}) when you push.`,\n57\t    `# Delete this block to disable, or set {\"transport\": {\"hook\": false}} in`,\n58\t    `# .cledger.json / ~/.config/cledger/config.json.`,\n59\t    `if [ -z \"$CLEDGER_INTERNAL\" ]; then`,\n60\t    `  if [ -x \"${node}\" ] && [ -e \"${cli}\" ]; then`,\n61\t    `    \"${node}\" \"${cli}\" transport-push \"$1\" </dev/null || exit $?`,\n62\t    `  elif command -v cledger >/dev/null 2>&1; then`,\n63\t    `    cledger transport-push \"$1\" </dev/null || exit $?`,\n64\t    `  fi`,\n65\t    `fi`,\n66\t    `# <<< ${HOOK_MARKER} <<<`,\n67\t  ].join(\"\\n\");\n68\t}\n69\t\n70\t/** Warnings that should print once per repo, not on every capture. */\n71\tasync function warnOnce(repo: RepoInfo, key: string, message: string): Promise<void> {\n72\t  const stateDir = join(repo.gitDir, \"conversation-ledger\");\n73\t  const path = join(stateDir, \"transport-warnings.json\");\n74\t  let warned: string[] = [];\n75\t  try {\n76\t    warned = JSON.parse(await readFile(path, \"utf8\")) as string[];\n77\t  } catch {\n78\t    // first warning, or unreadable state — state is rebuildable\n79\t  }\n80\t  if (warned.includes(key)) return;\n81\t  process.stderr.write(message);\n82\t  await mkdir(stateDir, { recursive: true });\n83\t  await writeFile(path, JSON.stringify([...warned, key]) + \"\\n\");\n84\t}\n85\t\n86\texport interface TransportSetup {\n87\t  hook: \"installed\" | \"present\" | \"appended\" | \"skipped-config\" | \"skipped-hookspath\" | \"skipped-foreign\";\n88\t  refspec: \"added\" | \"present\" | \"skipped-config\" | \"no-remote\";\n89\t}\n90\t\n91\t/**\n92\t * Transport is default-on but must cost the user nothing to get: the first\n93\t * capture in a repo wires it up. Installs the pre-push hook (chain-safe:\n94\t * appends to an existing shell hook, backs off with a one-time warning when\n95\t * core.hooksPath or a non-shell hook owns the file) and adds the fetch\n96\t * refspec that stages the remote's ledger ref on normal `git fetch`.\n97\t * Runs on every append — each check is a cheap stat/config read — so a\n98\t * remote added later still gets wired. Never throws: this runs inside\n99\t * capture, which must never fail a user's session.\n100\t */\n101\texport async function ensureTransport(\n102\t  repo: RepoInfo,\n103\t  config: CledgerConfig,\n104\t): Promise<TransportSetup | null> {\n105\t  try {\n106\t    return {\n107\t      hook: await ensurePrePushHook(repo, config),\n108\t      refspec: await ensureFetchRefspec(repo, config),\n109\t    };\n110\t  } catch {\n111\t    return null;\n112\t  }\n113\t}\n114\t\n115\tasync function ensurePrePushHook(\n116\t  repo: RepoInfo,\n117\t  config: CledgerConfig,\n118\t): Promise<TransportSetup[\"hook\"]> {\n119\t  if (config.transport?.hook === false) return \"skipped-config\";\n120\t\n121\t  const hooksPath = (await git([\"config\", \"--get\", \"core.hooksPath\"], {\n122\t    cwd: repo.root,\n123\t    allowFailure: true,\n124\t  })).trim();\n125\t  if (hooksPath) {\n126\t    await warnOnce(\n127\t      repo,\n128\t      \"hookspath\",\n129\t      `cledger: core.hooksPath is set (${hooksPath}), so the ledger pre-push hook was not ` +\n130\t        `installed. To share conversation records on push, add\\n` +\n131\t        `  cledger transport-push \"$1\"\\n` +\n132\t        `to that pre-push hook, or run \\`cledger sync\\` manually.\\n`,\n133\t    );\n134\t    return \"skipped-hookspath\";\n135\t  }\n136\t\n137\t  const hookPath = join(repo.gitDir, \"hooks\", \"pre-push\");\n138\t  if (!existsSync(hookPath)) {\n139\t    await mkdir(join(repo.gitDir, \"hooks\"), { recursive: true });\n140\t    await writeFile(hookPath, `#!/bin/sh\\n${hookBlock()}\\n`);\n141\t    await chmod(hookPath, 0o755);\n142\t    return \"installed\";\n143\t  }\n144\t\n145\t  const existing = await readFile(hookPath, \"utf8\");\n146\t  if (existing.includes(HOOK_MARKER)) return \"present\";\n147\t\n148\t  const shebang = existing.split(\"\\n\", 1)[0] ?? \"\";\n149\t  if (!/^#!.*\\b(sh|bash|zsh|dash|ksh)\\b/.test(shebang)) {\n150\t    await warnOnce(\n151\t      repo,\n152\t      \"foreign-hook\",\n153\t      `cledger: this repo's pre-push hook is not a shell script, so the ledger hook was not ` +\n154\t        `chained onto it. Run \\`cledger sync\\` to share conversation records manually.\\n`,\n155\t    );\n156\t    return \"skipped-foreign\";\n157\t  }\n158\t\n159\t  await writeFile(hookPath, existing.replace(/\\n?$/, \"\\n\") + \"\\n\" + hookBlock() + \"\\n\");\n160\t  await chmod(hookPath, 0o755);\n161\t  return \"appended\";\n162\t}\n163\t\n164\tasync function ensureFetchRefspec(\n165\t  repo: RepoInfo,\n166\t  config: CledgerConfig,\n167\t): Promise<TransportSetup[\"refspec\"]> {\n168\t  if (config.transport?.fetchRefspec === false) return \"skipped-config\";\n169\t\n170\t  const originUrl = (await git([\"remote\", \"get-url\", \"origin\"], {\n171\t    cwd: repo.root,\n172\t    allowFailure: true,\n173\t  })).trim();\n174\t  if (!originUrl) return \"no-remote\";\n175\t\n176\t  const fetchSpecs = await git([\"config\", \"--get-all\", \"remote.origin.fetch\"], {\n177\t    cwd: repo.root,\n178\t    allowFailure: true,\n179\t  });\n180\t  if (fetchSpecs.includes(INCOMING_REF)) return \"present\";\n181\t\n182\t  await git([\"config\", \"--add\", \"remote.origin.fetch\", FETCH_REFSPEC], { cwd: repo.root });\n183\t  return \"added\";\n184\t}\n185\t\n186\t/**\n187\t * Fold the staged incoming ref (populated by `git fetch` via the refspec)\n188\t * into the local ledger ref — the lazy, read-time half of transport. The\n189\t * merge is the same cat_sort_uniq union sync() uses, so absorbing can only\n190\t * add events. Returns true when new remote state was absorbed. Never\n191\t * throws: a concurrent notes merge just means the next read tries again.\n192\t */\n193\texport async function absorbIncoming(repo: RepoInfo): Promise<boolean> {\n194\t  const incoming = (await git([\"rev-parse\", \"--verify\", \"--quiet\", INCOMING_REF], {\n195\t    cwd: repo.root,\n196\t    allowFailure: true,\n197\t  })).trim();\n198\t  if (!incoming) return false;\n199\t\n200\t  const local = (await git([\"rev-parse\", \"--verify\", \"--quiet\", NOTES_REF], {\n201\t    cwd: repo.root,\n202\t    allowFailure: true,\n203\t  })).trim();\n204\t  if (local === incoming) {\n205\t    await git([\"update-ref\", \"-d\", INCOMING_REF], { cwd: repo.root, allowFailure: true });\n206\t    return false;\n207\t  }\n208\t\n209\t  try {\n210\t    await ensureMergeConfig(repo);\n211\t    if (!local) {\n212\t      await git([\"update-ref\", NOTES_REF, incoming], { cwd: repo.root });\n213\t    } else {\n214\t      await git([\"notes\", \"--ref\", NOTES_NAME, \"merge\", \"-s\", \"cat_sort_uniq\", INCOMING_REF], {\n215\t        cwd: repo.root,\n216\t      });\n217\t    }\n218\t  } catch {\n219\t    return false;\n220\t  }\n221\t  await git([\"update-ref\", \"-d\", INCOMING_REF], { cwd: repo.root, allowFailure: true });\n222\t  return true;\n223\t}\n224\t\n225\t/**\n226\t * True when git can produce an explicit author identity (config or env —\n227\t * never a hostname guess; see gitUserIdentity). Used by `cledger install`\n228\t * to warn that captured human turns would be unattributed.\n229\t */\n230\texport async function hasAuthorIdentity(): Promise<boolean> {\n231\t  try {\n232\t    await execFileP(\"git\", [\"-c\", \"user.useConfigOnly=true\", \"var\", \"GIT_AUTHOR_IDENT\"]);\n233\t    return true;\n234\t  } catch {\n235\t    return false;\n236\t  }\n237\t}\n238\t","tool_use_id":"t