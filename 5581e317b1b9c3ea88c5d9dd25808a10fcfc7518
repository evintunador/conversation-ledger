n\"], { cwd: dir });\n  return dir;\n}\n\n/** Recursively remove a temp repo/dir. Safe no-op if already gone. */\nexport async function cleanupDir(dir: string): Promise<void> {\n  await rm(dir, { recursive: true, force: true });\n}\n\nexport async function cleanupRepo(repo: RepoInfo): Promise<void> {\n  await cleanupDir(repo.root);\n}\n\n/** Create a commit (empty by default) and return its SHA. */\nexport async function makeCommit(repo: RepoInfo, message = \"commit\"): Promise<string> {\n  await git([\"commit\", \"--allow-empty\", \"-q\", \"-m\", message], { cwd: repo.root });\n  return (await git([\"rev-parse\", \"HEAD\"], { cwd: repo.root })).trim();\n}\n\n/** Build a minimal, valid EventDraft with sensible defaults, override at will. */\nexport function draft(overrides: Partial<EventDraft> = {}): EventDraft {\n  const base: EventDraft = {\n    kind: \"conversation_turn\",\n    occurred_at: \"2026-01-01T00:00:00.000Z\",\n    actor: { type: \"human\" },\n    producer: { tool: \"cledger\" },\n    content: { text: \"hello\" },\n  };\n  return { ...base, ...overrides };\n}\n\n/** Build a fully finalized event from overrides (id/schema/recorded_at auto-filled). */\nexport function event(overrides: Partial<EventDraft> = {}, now?: Date): EvidenceEvent {\n  return finalizeEvent(draft(overrides), now);\n}\n","filePath":"/Users/evintunador/repos/evintunador/conversation-ledger/src/test/helpers.ts","numLines":86,"startLine":1,"totalLines":86},"type":"text"},"type":"user","userType":"external","uuid":"1b26a38d-376c-4e7c-ac14-2e0b3158136f","version":"2.1.216"},"format":"claude-code-jsonl/1"},"recorded_at":"2026-07-21T06:36:17.901Z","schema":"conversation-ledger/v1"}
{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\timport { canonicalJson, sha256Hex } from \"./canonical.js\";\n2\timport type { RedactionRecord } from \"./redact/apply.js\";\n3\t\n4\texport const SCHEMA_VERSION = \"conversation-ledger/v1\";\n5\t\n6\t/**\n7\t * The well-known event kinds. `kind` is an open string so downstream tools\n8\t * can extend the ledger without a schema release; unknown kinds are stored\n9\t * verbatim. The ledger never interprets content, whatever the kind.\n10\t *\n11\t * `unrecognized` is the one kind the ledger emits for content it could *not*\n12\t * interpret: an adapter that meets a transcript line type it has no mapping\n13\t * for preserves the line raw-only under `raw.data` rather than dropping it,\n14\t * so a later adapter version can re-normalize (and supersede) it. Its\n15\t * `content` carries only a `{unrecognized_type}` label — the payload lives in\n16\t * `raw` — but identity still separates distinct lines via `conversation.seq`.\n17\t */\n18\texport const KNOWN_KINDS = [\n19\t  \"conversation_turn\",\n20\t  \"decision\",\n21\t  \"document\",\n22\t  \"annotation\",\n23\t  \"redaction\",\n24\t  \"supersession\",\n25\t  \"unrecognized\",\n26\t] as const;\n27\t\n28\texport interface Actor {\n29\t  /** \"human\" | \"agent\" | \"system\" */\n30\t  type: string;\n31\t  /** Stable identity when known, e.g. git author email or model id. */\n32\t  id?: string;\n33\t  display?: string;\n34\t}\n35\t\n36\texport interface Producer {\n37\t  /** Capture tool that wrote this event, e.g. \"cledger\". */\n38\t  tool: string;\n39\t  /** Capture tool version. Not part of event identity. */\n40\t  version?: string;\n41\t  /** Source system the content came from, e.g. \"claude-code\", \"codex\". */\n42\t  source?: string;\n43\t  /** Source system's native session identifier. */\n44\t  session_id?: string;\n45\t}\n46\t\n47\texport interface RepoContext {\n48\t  /** Best-known repository identity (origin URL or top-level dir name). */\n49\t  repo?: string;\n50\t  branch?: string;\n51\t  /** HEAD commit SHA at capture time. */\n52\t  head?: string;\n53\t  /** Working directory the conversation ran in. */\n54\t  cwd?: string;\n55\t  /** sha256 of `git status --porcelain` output when the tree was dirty. */\n56\t  dirty_fingerprint?: string;\n57\t}\n58\t\n59\texport interface ConversationRef {\n60\t  /** Namespaced conversation id, e.g. \"claude-code:<session uuid>\". */\n61\t  id: string;\n62\t  /** Stable ordering key within the conversation (source line index). */\n63\t  seq: number;\n64\t}\n65\t\n66\texport interface EventLink {\n67\t  /** e.g. \"redacts\", \"supersedes\", \"annotates\", \"replies_to\" */\n68\t  rel: string;\n69\t  /** Target event id. */\n70\t  target: string;\n71\t}\n72\t\n73\texport interface EvidenceEvent {\n74\t  /** \"ev1-\" + sha256 of the identity subset (see eventId). */\n75\t  id: string;\n76\t  schema: typeof SCHEMA_VERSION;\n77\t  kind: string;\n78\t  /** When the content happened, ISO 8601 UTC (from the source when known). */\n79\t  occurred_at: string;\n80\t  /** When this event was appended to the ledger. Not part of identity. */\n81\t  recorded_at: string;\n82\t  actor: Actor;\n83\t  producer: Producer;\n84\t  /** IANA media type of `content`; defaults to application/json. */\n85\t  media_type?: string;\n86\t  /** The visible content itself, stored inline and never reinterpreted. */\n87\t  content: unknown;\n88\t  /** Repository context at capture time. Not part of identity. */\n89\t  context?: RepoContext;\n90\t  conversation?: ConversationRef;\n91\t  links?: EventLink[];\n92\t  /**\n93\t   * Opaque source-native payload for lossless export, e.g. the original\n94\t   * transcript line(s). Versioned by `format`. Not part of identity.\n95\t   */\n96\t  raw?: { format: string; data: unknown };\n97\t  /**\n98\t   * Capture-time redaction records (rule id, ruleset version, fingerprint,\n99\t   * location path), pr