{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\t#!/usr/bin/env node\n2\timport { readFileSync } from \"node:fs\";\n3\timport { stdin as input } from \"node:process\";\n4\timport { findRepo, type RepoInfo } from \"./git.js\";\n5\timport {\n6\t  appendEvents,\n7\t  readEvents,\n8\t  redactEvent,\n9\t  ScanBlockedError,\n10\t  sortEvents,\n11\t  sync,\n12\t  transportPush,\n13\t  type ReadOptions,\n14\t} from \"./store.js\";\n15\timport { parseEventLine, type EventDraft, type EvidenceEvent } from \"./schema.js\";\n16\timport { runClaudeCodeHook, captureClaudeTranscript } from \"./adapters/claude-code.js\";\n17\timport { runCodexHook, captureCodexTranscript } from \"./adapters/codex.js\";\n18\timport { renormalize } from \"./renormalize.js\";\n19\timport { installAdapters } from \"./install.js\";\n20\timport {\n21\t  addToAllowlist,\n22\t  filterFindings,\n23\t  formatFinding,\n24\t  loadAllowlist,\n25\t  scanEvents,\n26\t} from \"./redact/scan.js\";\n27\t\n28\tconst USAGE = `conversation-ledger — durable records of coding-agent conversations, in git notes\n29\t\n30\tUsage:\n31\t  cledger append [--quiet]                 append JSONL events/drafts from stdin\n32\t  cledger log [--all|--rev R] [--kind K] [--source S] [--conversation C] [--json]\n33\t  cledger show <conversation-id-prefix> [--json]\n34\t  cledger conversations [--rev R]         list conversations on current branch (--all for every branch)\n35\t  cledger export [--rev R]                lossless JSONL dump (default: everything)\n36\t  cledger sync [--remote R] [--push|--fetch] [--no-scan] [--paranoid]\n37\t                                           fetch/merge/push of the ledger ref;\n38\t                                           push is gated by a secret scan unless --no-scan\n39\t  cledger transport-push [remote]         pre-push hook entrypoint (installed automatically):\n40\t                                           pushes the ledger ref alongside git push; scan findings\n41\t                                           hold back only the ledger unless transport.strict\n42\t  cledger scan [--all|--rev R] [--paranoid]   scan local events for potential secrets (CI-friendly:\n43\t                                           exits 1 if any finding, 0 otherwise); default scope is\n44\t                                           every local event, --rev restricts by reachability\n45\t  cledger allow <fingerprint...>          mark scan finding fingerprint(s) as known false positives\n46\t  cledger redact <event-id-prefix> (--pattern REGEX | --all) [--reason TEXT]\n47\t                                           rewrite an existing event to remove a secret, keeping its\n48\t                                           id stable, and squash local notes history if unpushed\n49\t  cledger renormalize                      re-interpret preserved unrecognized transcript lines this\n50\t                                           cledger version can now parse into conversation_turns,\n51\t                                           superseding the raw-only placeholders (append-only, idempotent)\n52\t  cledger install <claude-code|codex|all>  hook capture into coding CLIs (global)\n53\t  cledger hook <claude-code>              capture entrypoint invoked by CLI hooks (stdin: hook payload)\n54\t  cledger capture <claude-code|codex> --transcript PATH   manual/backfill ingestion\n55\t  cledger --version | --help\n56\t\n57\tEvents are anchored to the HEAD commit at capture time and stored under\n58\trefs/notes/conversation-ledger, so they follow branches through merges and\n59\tsync only when you say so.`;\n60\t\n61\tfunction version(): string {\n62\t  const pkg = JSON.parse(\n63\t    readFileSync(new URL(\"../package.json\", import.meta.url), \"utf8\"),\n64\t  ) as { version: string };\n65\t  return pkg.version;\n66\t}\n67\t\n68\tinterface Flags {\n69\t  [key: string]: string | boolean;\n70\t}\n71\t\n72\tfunction parseArgs(argv: string[]): { positional: string[]; flags: Flags } {\n73\t  const positional: string[] = [];\n74\t  const flags: Flags = {};\n75\t  for (let i = 0; i < argv.length; i++) {\n76\t    const arg = argv[i]!;\n77\t    if (arg.startsWith(\"--\")) {\n78\t      const name = arg.slice(2);\n79\t      const next = argv[i + 1];\n80\t      if (next !== undefined && !next.startsWith(\"--\")) {\n81\t        flags[name] = next;\n82\t        i++;\n83\t      } else {\n84\t        flags[name] = true;\n85\t      }\n86\t    } else {\n87\t      positional.push(arg);\n88\t    }\n89\t  }\n90\t  return { positional, flags };\n91\t}\n92\t\n93\tasync function requireRepo(): Promise<RepoInfo> {\n94\t  const repo = await findRepo(process.cwd());\n95\t  if (!repo) {\n96\t    process.stderr.write(\"cledger: not inside a git repository\\n\");\n97\t    process.exit(2);\n98\t  }\n99\t  return repo;\n100\t}\n101\t\n102\tasync function readStdin(): Promise<string> {\n103\t  const chunks: Buffer[] = [];\n104\t  for await (const chunk of input) chunks.push(chunk as Buffer);\n105\t  return Buffer.concat(chunks).toString(\"utf8\");\n106\t}\n107\t\n108\tfunction readOptionsFrom(flags: Flags): ReadOptions {\n109\t  const opts: ReadOptions = {};\n110\t  if (!flags[\"all\"]) opts.reachableFrom = typeof flags[\"rev\"] === \"string\" ? flags[\"rev\"] : \"HEAD\";\n111\t  if (typeof flags[\"kind\"] === \"string\") opts.kind = flags[\"kind\"];\n112\t  if (typeof flags[\"source\"] === \"string\") opts.source = flags[\"source\"];\n113\t  if (typeof flags[\"conversation\"] === \"string\") opts.conversation = flags[\"conversation\"];\n114\t  return opts;\n115\t}\n116\t\n117\tfunction snippet(event: EvidenceEvent): string {\n118\t  const c = event.content as Record<string, unknown> | string | null;\n119\t  let text = \"\";\n120\t  if (typeof c === \"string\") text = c;\n121\t  else if (c && typeof c === \"object\") {\n122\t    text = String(c[\"text\"] ?? c[\"summary\"] ?? c[\"title\"] ?? JSON.stringify(c));\n123\t  }\n124\t  text = text.replace(/\\s+/g, \" \").trim();\n125\t  return text.length > 100 ? text.slice(0, 97) + \"...\" : text;\n126\t}\n127\t\n128\tfunction printHuman(events: EvidenceEvent[]): void {\n129\t  for (const e of events) {\n130\t    const conv = e.conversation ? `${e.conversation.id.slice(0, 28)}#${e.conversation.seq}` : \"-\";\n131\t    const role =\n132\t      (e.content as Record<string, unknown> | null | undefined) &&\n133\t      typeof e.content === \"object\"\n134\t        ? String((e.content as Record<string, unknown>)[\"role\"] ?? e.actor.type)\n135\t        : e.actor.type;\n136\t    process.stdout.write(\n137\t      `${e.occurred_at}  ${e.kind}  ${role.padEnd(9)}  ${conv}  ${snippet(e)}\\n`,\n138\t    );\n139\t  }\n140\t}\n141\t\n142\tfunction printJsonl(events: EvidenceEvent[], includeRaw: boolean): void {\n143\t  for (const e of events) {\n144\t    const out = includeRaw ? e : { ...e, raw: undefined };\n145\t    process.stdout.write(JSON.stringify(out) + \"\\n\");\n146\t  }\n147\t}\n148\t\n149\tasync function cmdAppend(flags: Flags): Promise<void> {\n150\t  const repo = await requireRepo();\n151\t  const body = await readStdin();\n152\t  const drafts: EventDraft[] = body\n153\t    .split(\"\\n\")\n154\t    .filter((l) => l.trim())\n155\t    .map((l) => JSON.parse(l) as EventDraft);\n156\t  if (drafts.length === 0) return;\n157\t  const result = await appendEvents(repo, drafts);\n158\t  if (!flags[\"quiet\"]) {\n159\t    for (const e of result.appended) process.stdout.write(e.id + \"\\n\");\n160\t    process.stderr.write(\n161\t      `appended ${result.appended.length}, deduped ${result.deduped}` +\n162\t        (result.anchor ? ` (anchor ${result.anchor.slice(0, 12)})` : \" (pending: no commits yet)\") +\n163\t        \"\\n\",\n164\t    );\n165\t  }\n166\t}\n167\t\n168\tasync function cmdLog(flags: Flags): Promise<void> {\n169\t  const repo = await requireRepo();\n170\t  const events = await readEvents(repo, readOptionsFrom(flags));\n171\t  if (flags[\"json\"]) printJsonl(events, false);\n172\t  else printHuman(events);\n173\t}\n174\t\n175\tasync function cmdShow(positional: string[], flags: Flags): Promise<void> {\n176\t  const prefix = positional[0];\n177\t  if (!prefix) {\n178\t    process.stderr.write(\"usage: cledger show <conversation-id-prefix>\\n\");\n179\t    process.exit(2);\n180\t  }\n181\t  const repo = await requireRepo();\n182\t  const events = await readEvents(repo, { conversation: prefix });\n183\t  if (events.length === 0) {\n184\t    process.stderr.write(`no events for conversation ${prefix}\\n`);\n185\t    process.exit(1);\n186\t  }\n187\t  if (flags[\"json\"]) {\n188\t    printJsonl(events, true);\n189\t    return;\n190\t  }\n191\t  for (const e of sortEvents(events)) {\n192\t    const c = e.content as Record<string, unknown>;\n193\t    const role = typeof c === \"object\" && c ? String(c[\"role\"] ?? e.actor.type) : e.actor.type;\n194\t    const text =\n195\t      typeof c === \"object\" && c && typeof c[\"text\"] === \"string\"\n196\t        ? (c[\"text\"] as string)\n197\t        : JSON.stringify(e.content, null, 2);\n198\t    process.stdout.write(`\\n[${e.occurred_at}] ${role} (${e.kind}, ${e.id.slice(0, 16)})\\n`);\n199\t    process.stdout.write(text.trimEnd() + \"\\n\");\n200\t  }\n201\t}\n202\t\n203\tasync function cmdConversations(flags: Flags): Promise<void> {\n204\t  const repo = await requireRepo();\n205\t  const events = await readEvents(repo, readOptionsFrom(flags));\n206\t  const byConv = new Map<string, { count: number; first: string; last: string; source: string }>();\n207\t  for (const e of events) {\n208\t    const id = e.conversation?.id ?? \"(none)\";\n209\t    const entry = byConv.get(id) ?? {\n210\t      count: 0,\n211\t      first: e.occurred_at,\n212\t      last: e.occurred_at,\n213\t      source: e.producer.source ?? e.producer.tool,\n214\t    };\n215\t    entry.count++;\n216\t    if (e.occurred_at < entry.first) entry.first = e.occurred_at;\n217\t    if (e.occurred_at > entry.last) entry.last = e.occurred_at;\n218\t    byConv.set(id, entry);\n219\t  }\n220\t  for (const [id, s] of [...byConv.entries()].sort((a, b) => a[1].last.localeCompare(b[1].last))) {\n221\t    process.stdout.write(`${id}  ${s.source}  ${s.count} events  ${s.first} .. ${s.last}\\n`);\n222\t  }\n223\t}\n224\t\n225\tasync function cmdExport(flags: Flags): Promise<void> {\n226\t  const repo = await requireRepo();\n227\t  const opts: ReadOptions = {};\n228\t  if (typeof flags[\"rev\"] === \"string\") opts.reachableFrom = flags[\"rev\"];\n229\t  const events = await readEvents(repo, opts);\n230\t  printJsonl(events, true);\n231\t}\n232\t\n233\tasync function cmdSync(flags: Flags): Promise<void> {\n234\t  const repo = await requireRepo();\n235\t  const remote = typeof flags[\"remote\"] === \"string\" ? flags[\"remote\"] : \"origin\";\n236\t  const mode = flags[\"push\"] ? \"push\" : flags[\"fetch\"] ? \"fetch\" : \"both\";\n237\t  const result = await sync(repo, remote, mode, {\n238\t    skipScan: flags[\"no-scan\"] === true,\n239\t    paranoid: flags[\"paranoid\"] === true,\n240\t  });\n241\t  process.stderr.write(\n242\t    `sync ${remote}: ${result.fetched ? \"fetched+merged\" : \"nothing fetched\"}, ` +\n243\t      `${result.pushed ? \"pushed\" : \"not pushed\"}\\n`,\n244\t  );\n245\t}\n246\t\n247\tasync function cmdTransportPush(positional: string[]): Promise<void> {\n248\t  const repo = await findRepo(process.cwd());\n249\t  if (!repo) return; // a hook must never fail the user's push\n250\t  const remote = positional[0] || \"origin\";\n251\t  try {\n252\t    await transportPush(repo, remote);\n253\t  } catch (err) {\n254\t    if (err instanceof ScanBlockedError) {\n255\t      // transport.strict: nonzero exit makes git abort the entire push.\n256\t      process.stderr.write(\"cledger: entire push blocked (transport.strict is enabled)\\n\");\n257\t      process.exit(1);\n258\t    }\n259\t    // Anything else is a cledger bug or environment problem; the user's\n260\t    // code push must proceed regardless.\n261\t    process.stderr.write(\n262\t      `cledger: transport-push error (push continues): ${err instanceof Error ? err.message : String(err)}\\n`,\n263\t    );\n264\t  }\n265\t}\n266\t\n267\tasync function cmdScan(flags: Flags): Promise<void> {\n268\t  const repo = await requireRepo();\n269\t  const tier: \"standard\" | \"paranoid\" = flags[\"paranoid\"] ? \"paranoid\" : \"standard\";\n270\t  const opts: ReadOptions = {};\n271\t  if (typeof flags[\"rev\"] === \"string\") opts.reachableFrom = flags[\"rev\"];\n272\t  const events = await readEvents(repo, opts);\n273\t  const findings = filterFindings(scanEvents(events, tier), await loadAllowlist(repo));\n274\t  if (findings.length === 0) {\n275\t    process.stderr.write(\"cledger scan: no findings\\n\");\n276\t    return;\n277\t  }\n278\t  for (const f of findings) process.stdout.write(formatFinding(f) + \"\\n\");\n279\t  process.stderr.write(`cledger scan: ${findings.length} finding(s)\\n`);\n280\t  process.exit(1);\n281\t}\n282\t\n283\tasync function cmdAllow(positional: string[]): Promise<void> {\n284\t  if (positional.length === 0) {\n285\t    process.stderr.write(\"usage: cledger allow <fingerprint...>\\n\");\n286\t    process.exit(2);\n287\t  }\n288\t  const repo = await requireRepo();\n289\t  await addToAllowlist(repo, positional);\n290\t  process.stderr.write(`allowlisted ${positional.length} fingerprint(s)\\n`);\n291\t}\n292\t\n293\tasync function cmdRedact(positional: string[], flags: Flags): Promise<void> {\n294\t  const idPrefix = positional[0];\n295\t  if (!idPrefix) {\n296\t    process.stderr.write(\"usage: cledger redact <event-id-prefix> (--pattern REGEX | --all) [--reason TEXT]\\n\");\n297\t    process.exit(2);\n298\t  }\n299\t  const repo = await requireRepo();\n300\t  const redactOpts: { pattern?: string; all?: boolean; reason?: string } = {};\n301\t  if (typeof flags[\"pattern\"] === \"string\") redactOpts.pattern = flags[\"pattern\"];\n302\t  if (flags[\"all\"] === true) redactOpts.all = true;\n303\t  if (typeof flags[\"reason\"] === \"string\") redactOpts.reason = flags[\"reason\"];\n304\t  const result = await redactEvent(repo, idPrefix, redactOpts);\n305\t  const fingerprints = result.event.redactions?.map((r) => r.fingerprint).join(\", \") || \"(none)\";\n306\t  process.stderr.write(\n307\t    `cledger redact: rewrote ${result.event.id.slice(0, 16)} — fingerprints: ${fingerprints}\\n` +\n308\t      `companion event: ${result.redactionEvent.id.slice(0, 16)}\\n` +\n309\t      `history squashed: ${result.squashed ? \"yes\" : \"no\"}\\n`,\n310\t  );\n311\t  if (result.knownSecretsRemembered > 0) {\n312\t    process.stderr.write(\n313\t      `remembered ${result.knownSecretsRemembered} secret value(s) for capture-time redaction ` +\n314\t        `(redact.knownSecrets is on)\\n`,\n315\t    );\n316\t  }\n317\t}\n318\t\n319\tasync function cmdRenormalize(): Promise<void> {\n320\t  const repo = await requireRepo();\n321\t  const result = await renormalize(repo);\n322\t  process.stderr.write(\n323\t    `cledger renormalize: scanned ${result.scanned}, interpreted ${result.interpreted} ` +\n324\t      `(+${result.turnsAppended} turn(s), +${result.supersessionsAppended} supersession(s)), ` +\n325\t      `skipped ${result.skipped} still-unrecognized\\n`,\n326\t  );\n327\t}\n328\t\n329\tasync function main(): Promise<void> {\n330\t  const [, , command, ...rest] = process.argv;\n331\t  const { positional, flags } = parseArgs(rest);\n332\t\n333\t  if (!command || command === \"--help\" || command === \"help\") {\n334\t    process.stdout.write(USAGE + \"\\n\");\n335\t    return;\n336\t  }\n337\t  if (command === \"--version\") {\n338\t    process.stdout.write(version() + \"\\n\");\n339\t    return;\n340\t  }\n341\t  switch (command) {\n342\t    case \"append\":\n343\t      return cmdAppend(flags);\n344\t    case \"log\":\n345\t      return cmdLog(flags);\n346\t    case \"show\":\n347\t      return cmdShow(positi