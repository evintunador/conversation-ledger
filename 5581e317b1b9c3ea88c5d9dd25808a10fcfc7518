{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\timport { execFile } from \"node:child_process\";\n2\timport { promisify } from \"node:util\";\n3\t\n4\tconst execFileP = promisify(execFile);\n5\t\n6\texport class GitError extends Error {\n7\t  constructor(\n8\t    message: string,\n9\t    public readonly args: string[],\n10\t    public readonly stderr: string,\n11\t    public readonly code: number | undefined,\n12\t  ) {\n13\t    super(message);\n14\t  }\n15\t}\n16\t\n17\texport interface GitRunOptions {\n18\t  cwd: string;\n19\t  input?: string;\n20\t  allowFailure?: boolean;\n21\t}\n22\t\n23\texport async function git(args: string[], opts: GitRunOptions): Promise<string> {\n24\t  try {\n25\t    const child = execFileP(\"git\", args, {\n26\t      cwd: opts.cwd,\n27\t      maxBuffer: 512 * 1024 * 1024,\n28\t    });\n29\t    if (opts.input !== undefined) {\n30\t      child.child.stdin?.write(opts.input);\n31\t      child.child.stdin?.end();\n32\t    }\n33\t    const { stdout } = await child;\n34\t    return stdout;\n35\t  } catch (err) {\n36\t    const e = err as { stderr?: string; code?: number; message?: string };\n37\t    if (opts.allowFailure) return \"\";\n38\t    throw new GitError(\n39\t      `git ${args.join(\" \")} failed: ${e.stderr?.trim() || e.message}`,\n40\t      args,\n41\t      e.stderr ?? \"\",\n42\t      typeof e.code === \"number\" ? e.code : undefined,\n43\t    );\n44\t  }\n45\t}\n46\t\n47\texport interface RepoInfo {\n48\t  root: string;\n49\t  gitDir: string;\n50\t}\n51\t\n52\t/** Resolve the repo containing dir, or null when outside any git repo. */\n53\texport async function findRepo(dir: string): Promise<RepoInfo | null> {\n54\t  try {\n55\t    const root = (await git([\"rev-parse\", \"--show-toplevel\"], { cwd: dir })).trim();\n56\t    const gitDir = (await git([\"rev-parse\", \"--absolute-git-dir\"], { cwd: dir })).trim();\n57\t    return { root, gitDir };\n58\t  } catch {\n