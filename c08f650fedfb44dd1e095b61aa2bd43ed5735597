{"actor":{"type":"human"},"content":{"blocks":[{"content":"1\timport { mkdir, readFile, rm, writeFile } from \"node:fs/promises\";\n2\timport { existsSync } from \"node:fs\";\n3\timport { join } from \"node:path\";\n4\timport { sha256Hex } from \"./canonical.js\";\n5\timport {\n6\t  currentBranch,\n7\t  git,\n8\t  headSha,\n9\t  repoIdentity,\n10\t  revList,\n11\t  statusPorcelain,\n12\t  type RepoInfo,\n13\t} from \"./git.js\";\n14\timport {\n15\t  finalizeEvent,\n16\t  parseEventLine,\n17\t  serializeEvent,\n18\t  type EventDraft,\n19\t  type EvidenceEvent,\n20\t  type RepoContext,\n21\t} from \"./schema.js\";\n22\t\n23\texport const NOTES_NAME = \"conversation-ledger\";\n24\texport const NOTES_REF = `refs/notes/${NOTES_NAME}`;\n25\t\n26\t/**\n27\t * Storage model: one git note per anchor commit under refs/notes/\n28\t * conversation-ledger. The note body is JSONL — one canonical-JSON event\n29\t * per line, lexicographically sorted, unique. Everything lives in the note\n30\t * blob itself (no out-of-tree pointers), so records are reachable from the\n31\t * ref, GC-safe, travel with `git push`/`fetch` of that one ref, and merge\n32\t * conflict-free with the cat_sort_uniq notes strategy.\n33\t *\n34\t * Events are anchored to HEAD at capture time, so conversations ride the\n35\t * commit DAG: merge a branch and its conversations become reachable from\n36\t * the target branch with no extra machinery.\n37\t */\n38\t\n39\tfunction stateDir(repo: RepoInfo): string {\n40\t  return join(repo.gitDir, \"conversation-ledger\");\n41\t}\n42\t\n43\tfunction pendingPath(repo: RepoInfo): string {\n44\t  return join(stateDir(repo), \"pending.jsonl\");\n45\t}\n46\t\n47\t/** Local, rebuildable cache/state only — never the record of truth. */\n48\tasync function ensureStateDir(repo: RepoInfo): Promise<void> {\n49\t  await mkdir(stateDir(repo), { recursive: true });\n50\t}\n51\t\n52\texport async function ensureMergeConfig(repo: RepoInfo): Promise<void> {\n53\t  const key = `notes.${NOTES_NAME}.mergeStrategy`;\n54\t  const current = (await git([\"config\", \"--get\", key], {\n55\t    cwd: repo.root,\n56\t    allowFailure: true,\n57\t  })).trim();\n58\t  if (current !== \"cat_sort_uniq\") {\n59\t    await git([\"config\", key, \"cat_sort_uniq\"], { cwd: repo.root });\n60\t  }\n61\t}\n62\t\n63\texport async function captureContext(repo: RepoInfo): Promise<RepoContext> {\n64\t  const [identity, branch, head, status] = await Promise.all([\n65\t    repoIdentity(repo),\n66\t    currentBranch(repo),\n67\t    headSha(repo),\n68\t    statusPorcelain(repo),\n69\t  ]);\n70\t  const context: RepoContext = { repo: identity, cwd: repo.root };\n71\t  if (branch) context.branch = branch;\n72\t  if (head) context.head = head;\n73\t  if (status.trim()) context.dirty_fingerprint = sha256Hex(status);\n74\t  return context;\n75\t}\n76\t\n77\tasync function readNoteLines(repo: RepoInfo, anchor: string): Promise<string[]> {\n78\t  const body = await git([\"notes\", \"--ref\", NOTES_NAME, \"show\", anchor], {\n79\t    cwd: repo.root,\n80\t    allowFailure: true,\n81\t  });\n82\t  return body.split(\"\\n\").filter((l) => l.trim().length > 0);\n83\t}\n84\t\n85\texport async function readNoteEvents(repo: RepoInfo, anchor: string): Promise<EvidenceEvent[]> {\n86\t  return (await readNoteLines(repo, anchor)).map(parseEventLine);\n87\t}\n88\t\n89\t/** All (anchor commit, note) pairs in the ledger ref. */\n90\texport async function listAnchors(repo: RepoInfo): Promise<string[]> {\n91\t  const out = await git([\"notes\", \"--ref\", NOTES_NAME, \"list\"], {\n92\t    cwd: repo.root,\n93\t    allowFailure: true,\n94\t  });\n95\t  return out\n96\t    .split(\"\\n\")\n97\t    .filter(Boolean)\n98\t    .map((line) => line.split(/\\s+/)[1])\n99\t    .filter((sha): sha is string => Boolean(sha));\n100\t}\n101\t\n102\tasync function withLock<T>(repo: RepoInfo, fn: () => Promise<T>): Promise<T> {\n103\t  await ensureStateDir(repo);\n104\t  const lockDir = join(stateDir(repo), \"lock\");\n105\t  const deadline = Date.now() + 10_000;\n106\t  for (;;) {\n107\t    try {\n108\t      await mkdir(lockDir);\n109\t      break;\n110\t    } catch {\n111\t      if (Date.now() > deadline) {\n112\t        // A crashed writer can leave the lock behind; steal it after the\n113\t        // wait budget rather than wedging capture hooks forever.\n114\t        await rm(lockDir, { recursive: true, force: true });\n115\t      } else {\n116\t        await new Promise((r) => setTimeout(r, 100));\n117\t      }\n118\t    }\n119\t  }\n120\t  try {\n121\t    return await fn();\n122\t  } finally {\n123\t    await rm(lockDir, { recursive: true, force: true });\n124\t  }\n125\t}\n126\t\n127\texport interface AppendResult {\n128\t  appended: EvidenceEvent[];\n129\t  deduped: number;\n130\t  /** null when events went to the pending queue (unborn HEAD). */\n131\t  anchor: string | null;\n132\t}\n133\t\n134\texport async function appendEvents(\n135\t  repo: RepoInfo,\n136\t  drafts: EventDraft[],\n137\t  opts: { context?: RepoContext } = {},\n138\t): Promise<AppendResult> {\n139\t  const context = opts.context ?? (await captureContext(repo));\n140\t  const events = drafts.map((draft) =>\n141\t    finalizeEvent({ ...draft, context: draft.context ?? context }),\n142\t  );\n143\t  return withLock(repo, async () => {\n144\t    await ensureMergeConfig(repo);\n145\t    const anchor = await headSha(repo);\n146\t    if (!anchor) {\n147\t      return appendPending(repo, events);\n148\t    }\n149\t    const pending = await drainPending(repo);\n150\t    const existing = await readNoteLines(repo, anchor);\n151\t    const known = new Set(existing.map((l) => parseEventLine(l).id));\n152\t    const fresh = [...pending, ...events].filter((e) => {\n153\t      if (known.has(e.id)) return false;\n154\t      known.add(e.id);\n155\t      return true;\n156\t    });\n157\t    if (fresh.length === 0) {\n158\t      return { appended: [], deduped: events.length, anchor };\n159\t    }\n160\t    const lines = [...existing, ...fresh.map(serializeEvent)].sort();\n161\t    await git([\"notes\", \"--ref\", NOTES_NAME, \"add\", \"-f\", \"-F\", \"-\", anchor], {\n162\t      cwd: repo.root,\n163\t      input: lines.join(\"\\n\") + \"\\n\",\n164\t    });\n165\t    const freshIds = new Set(fresh.map((e) => e.id));\n166\t    return {\n167\t      appended: events.filter((e) => freshIds.has(e.id)),\n168\t      deduped: events.length - events.filter((e) => freshIds.has(e.id)).length,\n169\t      anchor,\n170\t    };\n171\t  });\n172\t}\n173\t\n174\tasync function appendPending(repo: RepoInfo, events: EvidenceEvent[]): Promise<AppendResult> {\n175\t  await ensureStateDir(repo);\n176\t  const path = pendingPath(repo);\n177\t  const existing = existsSync(path)\n178\t    ? (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean)\n179\t    : [];\n180\t  const known = new Set(existing.map((l) => parseEventLine(l).id));\n181\t  const fresh = events.filter((e) => !known.has(e.id));\n182\t  await writeFile(path, [...existing, ...fresh.map(serializeEvent)].join(\"\\n\") + \"\\n\");\n183\t  return { appended: fresh, deduped: events.length - fresh.length, anchor: null };\n184\t}\n185\t\n186\t/** Events held while HEAD was unborn; caller writes them into a real note. */\n187\tasync function drainPending(repo: RepoInfo): Promise<EvidenceEvent[]> {\n188\t  const path = pendingPath(repo);\n189\t  if (!existsSync(path)) return [];\n190\t  const events = (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean).map(parseEventLine);\n191\t  await rm(path, { force: true });\n192\t  return events;\n193\t}\n194\t\n195\texport async function readPending(repo: RepoInfo): Promise<EvidenceEvent[]> {\n196\t  const path = pendingPath(repo);\n197\t  if (!existsSync(path)) return [];\n198\t  return (await readFile(path, \"utf8\")).split(\"\\n\").filter(Boolean).map(parseEventLine);\n199\t}\n200\t\n201\texport interface ReadOptions {\n202\t  /** Restrict to events anchored to commits reachable from this rev. */\n203\t  reachableFrom?: string;\n204\t  kind?: string;\n205\t  source?: string;\n206\t  conversation?: string;\n207\t}\n208\t\n209\texport async function readEvents(repo: RepoInfo, opts: ReadOptions = {}): Promise<EvidenceEvent[]> {\n210\t  let anchors = await listAnchors(repo);\n211\t  if (opts.reachableFrom) {\n212\t    const reachable = await revList(repo, opts.reachableFrom);\n213\t    anchors = anchors.filter((a) => reachable.has(a));\n214\t  }\n215\t  const events: EvidenceEvent[] = [];\n216\t  for (const anchor of anchors) {\n217\t    events.push(...(await readNoteEvents(repo, anchor)));\n218\t  }\n219\t  events.push(...(await readPending(repo)));\n220\t  const filtered = events.filter(\n221\t    (e) =>\n222\t      (!opts.kind || e.kind === opts.kind) &&\n223\t      (!opts.source || e.producer.source === opts.source) &&\n224\t      (!opts.conversation || e.conversation?.id === opts.conversation ||\n225\t        e.conversation?.id.startsWith(opts.conversation)),\n226\t  );\n227\t  return sortEvents(filtered);\n228\t}\n229\t\n230\t/** Stable order: conversation, then seq, then time, then id. */\n231\texport function sortEvents(events: EvidenceEvent[]): EvidenceEvent[] {\n232\t  return [...events].sort((a, b) => {\n233\t    const conv = (a.conversation?.id ?? \"\").localeCompare(b.conversation?.id ?? \"\");\n234\t    if (conv !== 0) return conv;\n235\t    const seq = (a.conversation?.seq ?? 0) - (b.conversation?.seq ?? 0);\n236\t    if (seq !== 0) return seq;\n237\t    const time = a.occurred_at.localeCompare(b.occurred_at);\n238\t    if (time !== 0) return time;\n239\t    return a.id.localeCompare(b.id);\n240\t  });\n241\t}\n242\t\n243\texport interface SyncResult {\n244\t  fetched: boolean;\n245\t  pushed: boolean;\n246\t}\n247\t\n248\t/** Explicit, opt-in sync of the single ledger ref. Never runs implicitly. */\n249\texport async function sync(\n250\t  repo: RepoInfo,\n251\t  remote = \"origin\",\n252\t  mode: \"both\" | \"push\" | \"fetch\" = \"both\",\n253\t): Promise<SyncResult> {\n254\t  const result: SyncResult = { fetched: false, pushed: false };\n255\t  await ensureMergeConfig(repo);\n256\t  if (mode !== \"push\") {\n257\t    const incoming = \"refs/notes/conversation-ledger-incoming\";\n258\t    const fetched = await git(\n259\t      [\"fetch\", remote, `+${NOTES_REF}:${incoming}`],\n260\t      { cwd: repo.root, allowFailure: true },\n261\t    );\n262\t    void fetched;\n263\t    const hasIncoming = (await git([\"rev-parse\", \"--verify\", \"--quiet\", incoming], {\n264\t      cwd: repo.root,\n265\t      allowFailure: true,\n266\t    })).trim();\n267\t    if (hasIncoming) {\n268\t      await git(\n269\t        [\"notes\", \"--ref\", NOTES_NAME, \"merge\", \"-s\", \"cat_sort_uniq\", incoming],\n270\t        { cwd: repo.root },\n271\t      );\n272\t      await git([\"update-ref\", \"-d\", incoming], { cwd: repo.root, allowFailure: true });\n273\t      result.fetched = true;\n274\t    }\n275\t  }\n276\t  if (mode !== \"fetch\") {\n277\t    await git([\"push\", remote, `${NOTES_REF}:${NOTES_REF}`], { cwd: repo.root });\n278\t    result.pushed = true;\n279\t  }\n280\t  return result;\n281\t}\n282\t","tool_use_id":"toolu_01UKVowCys3mjAKeRyNNULWK","type":"tool_result"}],"role":"user"},"context":{"branch":"main","cwd":"/Users/evintunador/repos/evintunador/conversation-ledger","head":"c08f650fedfb44dd1e095b61aa2bd43ed5735597","repo":"git@github.com:evintunador/conversation-ledger.git"},"conversation":{"id":"claude-code:353eecbb-eaf7-4854-a575-a9d56e290707","seq":65},"id":"ev1-345c2c861387b5d54d241cd7c87469fd2754c9e454875e93761e73054544270a","kind":"conversation_turn","occurred_at":"2026-07-20T01:52:39.952Z","producer":{"session_id":"353eecbb-eaf7-4854-a575-a9d56e290707","source":"claude-code","tool":"cledger","version":"0.2.0"},"raw":{"data":{"cwd":"/Users/evintunador/repos/evintunador/conversation-ledger","entrypoint":"cli","gitBranch":"main","isSidechain":false,"message":{"content":[{"content":"1\timport