{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\timport { canonicalJson, sha256Hex } from \"./canonical.js\";\n2\timport type { RedactionRecord } from \"./redact/apply.js\";\n3\t\n4\texport const SCHEMA_VERSION = \"conversation-ledger/v1\";\n5\t\n6\t/**\n7\t * The well-known event kinds. `kind` is an open string so downstream tools\n8\t * can extend the ledger without a schema release; unknown kinds are stored\n9\t * verbatim. The ledger never interprets content, whatever the kind.\n10\t *\n11\t * `unrecognized` is the one kind the ledger emits for content it could *not*\n12\t * interpret: an adapter that meets a transcript line type it has no mapping\n13\t * for preserves the line raw-only under `raw.data` rather than dropping it,\n14\t * so a later adapter version can re-normalize (and supersede) it. Its\n15\t * `content` carries only a `{unrecognized_type}` label — the payload lives in\n16\t * `raw` — but identity still separates distinct lines via `conversation.seq`.\n17\t */\n18\texport const KNOWN_KINDS = [\n19\t  \"conversation_turn\",\n20\t  \"decision\",\n21\t  \"document\",\n22\t  \"annotation\",\n23\t  \"redaction\",\n24\t  \"supersession\",\n25\t  \"re_anchor\",\n26\t  \"unrecognized\",\n27\t] as const;\n28\t\n29\texport interface Actor {\n30\t  /** \"human\" | \"agent\" | \"system\" */\n31\t  type: string;\n32\t  /** Stable identity when known, e.g. git author email or model id. */\n33\t  id?: string;\n34\t  display?: string;\n35\t}\n36\t\n37\texport interface Producer {\n38\t  /** Capture tool that wrote this event, e.g. \"cledger\". */\n39\t  tool: string;\n40\t  /** Capture tool version. Not part of event identity. */\n41\t  version?: string;\n42\t  /** Source system the content came from, e.g. \"claude-code\", \"codex\". */\n43\t  source?: string;\n44\t  /** Source system's native session identifier. */\n45\t  session_id?: string;\n46\t}\n47\t\n48\texport interface RepoContext {\n49\t  /** Best-known repository identity (origin URL or top-level dir name). */\n50\t  repo?: string;\n51\t  branch?: string;\n52\t  /** HEAD commit SHA at capture time. */\n53\t  head?: string;\n54\t  /** Working directory the conversation ran in. */\n55\t  cwd?: string;\n56\t  /** sha256 of `git status --porcelain` output when the tree was dirty. */\n57\t  dirty_fingerprint?: string;\n58\t}\n59\t\n60\texport interface ConversationRef {\n61\t  /** Namespaced conversation id, e.g. \"claude-code:<session uuid>\". */\n62\t  id: string;\n63\t  /** Stable ordering key within the conversation (source line index). */\n64\t  seq: number;\n65\t}\n66\t\n67\texport interface EventLink {\n68\t  /** e.g. \"redacts\", \"supersedes\", \"annotates\", \"replies_to\" */\n69\t  rel: string;\n70\t  /** Target event id. */\n71\t  target: string;\n72\t}\n73\t\n74\texport interface EvidenceEvent {\n75\t  /** \"ev1-\" + sha256 of the identity subset (see eventId). */\n76\t  id: string;\n77\t  schema: typeof SCHEMA_VERSION;\n78\t  kind: string;\n79\t  /** When the content happened, ISO 8601 UTC (from the source when known). */\n80\t  occurred_at: string;\n81\t  /** When this event was appended to the ledger. Not part of identity. */\n82\t  recorded_at: string;\n83\t  actor: Actor;\n84\t  producer: Producer;\n85\t  /** IANA media type of `content`; defaults to application/json. */\n86\t  media_type?: string;\n87\t  /** The visible content itself, stored inline and never reinterpreted. */\n88\t  content: unknown;\n89\t  /** Repository context at capture time. Not part of identity. */\n90\t  context?: RepoContext;\n91\t  conversation?: ConversationRef;\n92\t  links?: EventLink[];\n93\t  /**\n94\t   * Opaque source-native payload for lossless export, e.g. the original\n95\t   * transcript line(s). Versioned by `format`. Not part of identity.\n96\t   */\n97\t  raw?: { format: string; data: unknown };\n98\t  /**\n99\t   * Capture-time redaction records (rule id, ruleset version, fingerprint,\n100\t