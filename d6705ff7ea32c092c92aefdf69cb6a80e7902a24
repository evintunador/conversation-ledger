) => e.kind === \"unrecognized\")\n212\t      .sort((a, b) => (a.conversation!.seq - b.conversation!.seq));\n213\t    assert.strictEqual(preserved.length, 2);\n214\t\n215\t    const holo = preserved[0]!;\n216\t    assert.strictEqual(holo.actor.type, \"system\");\n217\t    assert.deepStrictEqual(holo.content, { unrecognized_type: \"response_item/holo_call\" });\n218\t    assert.strictEqual(holo.raw!.format, \"codex-rollout-jsonl/2\");\n219\t    // Full source line retained under raw.data for later re-normalization.\n220\t    assert.deepStrictEqual(holo.raw!.data, {\n221\t      type: \"response_item\",\n222\t      timestamp: \"2026-01-01T00:00:03.000Z\",\n223\t      payload: { type: \"holo_call\", text: \"future content kind\" },\n224\t    });\n225\t    assert.strictEqual(holo.occurred_at, \"2026-01-01T00:00:03.000Z\");\n226\t\n227\t    const brandNew = preserved[1]!;\n228\t    assert.deepStrictEqual(brandNew.content, { unrecognized_type: \"brand_new_line_kind\" });\n229\t    assert.deepStrictEqual(brandNew.raw!.data, { type: \"brand_new_line_kind\", payload: {} });\n230\t  } finally {\n231\t    await cleanupRepo(repo);\n232\t    await cleanupDir(dir);\n233\t  }\n234\t});\n235\t\n236\ttest(\"captureCodexTranscript: a secret inside an unrecognized line is redacted in raw\", async () => {\n237\t  const repo = await makeTempRepo(\"cledger-codex-drift-secret-\");\n238\t  const dir = await mkdtemp(join(tmpdir(), \"cledger-codex-drift-secret-\"));\n239\t  try {\n240\t    await makeCommit(repo, \"init\");\n241\t    const path = join(dir, FILENAME);\n242\t    const secret = \"ghp_\" + \"a\".repeat(36);\n243\t    const lines = [\n244\t      { type: \"session_meta\", payload: { session_id: SESSION_ID } },\n245\t      {\n246\t        type: \"response_item\",\n247\t        timestamp: \"2026-01-01T00:00:03.000Z\",\n248\t        payload: { type: \"holo_call\", token: secret },\n249\t      },\n250\t    ];\n251\t    await writeFile(path, lines.map((l) => JSON.stringify(l)).join(\"\\n