{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"1\t/**\n2\t * Format-drift handling shared by adapters. Adapters are tolerant parsers:\n3\t * a line type in neither the convertible set nor the deliberately-skipped set\n4\t * is *unrecognized* — most likely new upstream content this cledger version\n5\t * has no mapping for. Two things happen for such a line:\n6\t *\n7\t *  1. It is counted per type and surfaced in a capture-time warning (the\n8\t *     drift tripwire — \"the format changed, update cledger\").\n9\t *  2. It is preserved raw-only as an `unrecognized` event (see\n10\t *     `unrecognizedDraft`) instead of being dropped, so a later adapter\n11\t *     version can re-normalize the line rather than lose it forever.\n12\t *\n13\t * Preservation events ride the normal append path, so the capture-time\n14\t * redaction stack walks their `raw.data` exactly as it does interpreted\n15\t * events — an unrecognized line is not a hole in secret redaction.\n16\t */\n17\t\n18\timport type { EventDraft } from \"../schema.js\";\n19\t\n20\texport interface CaptureResult {\n21\t  appended: number;\n22\t  deduped: number;\n23\t  /** Skipped-line tallies keyed by unrecognized type, e.g. {\"response_item/agent_message\": 3}. */\n24\t  unrecognized: Record<string, number>;\n25\t}\n26\t\n27\texport function countUnrecognized(unrecognized: Record<string, number>, key: string): void {\n28\t  unrecognized[key] = (unrecognized[key] ?? 0) + 1;\n29\t}\n30\t\n31\t/**\n32\t * Build the raw-only preservation event for one unrecognized transcript line.\n33\t *\n34\t * `content` holds only the type label — the ledger did not interpret the\n35\t * line, so it claims no roles, no actor identity (actor is `system`), no\n36\t * structured blocks. The full source line lives under `raw.data`, versioned\n37\t * by `rawFormat` so a future adapter knows which native shape to re-parse.\n38\t *\n39\t * Identity: `raw` is excluded from the event id, but that is fine here —\n40\t * `conversation.seq` (the source line index, part of the identity subset)\n41\t * already makes distinct lines distinct and re-scans of the same line\n42\t * idempotent, the same guarantee interpreted turns rely on. Keeping the\n43\t * format marker in `raw` therefore means format-version bumps never churn\n44\t * ids, matching every other event kind.\n45\t */\n46\texport function unrecognizedDraft(params: {\n47\t  typeKey: string;\n48\t  line: unknown;\n49\t  occurredAt: string;\n50\t  source: string;\n51\t  sessionId: string;\n52\t  seq: number;\n53\t  version: string;\n54\t  rawFormat: string;\n55\t  conversationId: string;\n56\t}): EventDraft {\n57\t  return {\n58\t    kind: \"unrecognized\",\n59\t    occurred_at: params.occurredAt,\n60\t    actor: { type: \"system\" },\n61\t    producer: {\n62\t      tool: \"cledger\",\n63\t      version: params.version,\n64\t      source: params.source,\n65\t      session_id: params.sessionId,\n66\t    },\n67\t    conversation: { id: params.conversationId, seq: params.seq },\n68\t    content: { unrecognized_type: params.typeKey },\n69\t    raw: { format: params.rawFormat, data: params.line },\n70\t  };\n71\t}\n72\t\n73\texport function warnUnrecognized(source: string, unrecognized: Record<string, number>): void {\n74\t  const entries = Object.entries(unrecognized);\n75\t  if (entries.length === 0) return;\n76\t  const total = entries.reduce((n, [, c]) => n + c, 0);\n77\t  const detail = entries\n78\t    .sort((a, b) => b[1] - a[1])\n79\t    .map(([type, count]) => `${type} x${count}`)\n80\t    .join(\", \");\n81\t  process.stderr.write(\n82\t    `cledger: ${source} preserved ${total} transcript line(s) of unrecognized type (${detail}) ` +\n83\t      `raw-only — the ${source} format may have added content this cledger version cannot ` +\n84\t      `interpret; update conversation-ledger to normalize these, or report it\\n`,\n85\t  );\n86\t}\n87\t","tool_use_id":"toolu_01VAL5gniQ79A2