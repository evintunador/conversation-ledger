ell\", arguments: { command: \"pytest\" }, call_id: \"call_9\" },\n40\t    },\n41\t    {\n42\t      type: \"response_item\",\n43\t      timestamp: \"2026-01-01T00:00:04.000Z\",\n44\t      payload: { type: \"function_call_output\", call_id: \"call_9\", output: \"5 passed\" },\n45\t    },\n46\t    {\n47\t      type: \"response_item\",\n48\t      timestamp: \"2026-01-01T00:00:05.000Z\",\n49\t      payload: { type: \"reasoning\", encrypted_content: \"opaque-blob-must-never-be-stored\" },\n50\t    },\n51\t  ];\n52\t}\n53\t\n54\tasync function writeRollout(dir: string): Promise<string> {\n55\t  const path = join(dir, FILENAME);\n56\t  const lines = rolloutLines().map((l) => JSON.stringify(l));\n57\t  lines.push('{\"type\":\"response_item\",\"payload\":{\"type\":\"message\"');\n58\t  await writeFile(path, lines.join(\"\\n\") + \"\\n\");\n59\t  return path;\n60\t}\n61\t\n62\ttest(\"captureCodexTranscript: converts a synthetic rollout end to end\", async () => {\n63\t  const repo = await makeTempRepo(\"cledger-codex-\");\n64\t  const rolloutDir = await mkdtemp(join(tmpdir(), \"cledger-codex-transcript-\"));\n65\t  try {\n66\t    await makeCommit(repo, \"init\");\n67\t    const rolloutPath = await writeRollout(rolloutDir);\n68\t\n69\t    await captureCodexTranscript(rolloutPath, repo.root);\n70\t\n71\t    const events = await readEvents(repo);\n72\t    assert.strictEqual(events.length, 4, \"session_meta, reasoning, and malformed lines must be dropped\");\n73\t\n74\t    for (const e of events) {\n75\t      assert.strictEqual(e.raw?.format, \"codex-rollout-jsonl/2\");\n76\t      assert.strictEqual(e.conversation?.id, `codex:${SESSION_ID}`);\n77\t      assert.strictEqual(e.producer.source, \"codex\");\n78\t      assert.strictEqual(\n79\t        e.producer.session_id,\n80\t        SESSION_ID,\n81\t        \"session_meta's session_id must override the filename-derived id\",\n82\t      );\n83\t    }\n84\t\n85\t    // seq must equal the original line index (session_meta occupies ind