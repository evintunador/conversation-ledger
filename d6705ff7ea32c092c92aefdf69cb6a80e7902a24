{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"120\t  return Buffer.concat(chunks).toString(\"utf8\");\n121\t}\n122\t\n123\tfunction readOptionsFrom(flags: Flags): ReadOptions {\n124\t  const opts: ReadOptions = {};\n125\t  if (!flags[\"all\"]) opts.reachableFrom = typeof flags[\"rev\"] === \"string\" ? flags[\"rev\"] : \"HEAD\";\n126\t  if (typeof flags[\"kind\"] === \"string\") opts.kind = flags[\"kind\"];\n127\t  if (typeof flags[\"source\"] === \"string\") opts.source = flags[\"source\"];\n128\t  if (typeof flags[\"conversation\"] === \"string\") opts.conversation = flags[\"conversation\"];\n129\t  return opts;\n130\t}\n131\t\n132\tfunction snippet(event: EvidenceEvent): string {\n133\t  const c = event.content as Record<string, unknown> | string | null;\n134\t  let text = \"\";\n135\t  if (typeof c === \"string\") text = c;\n136\t  else if (c && typeof c === \"object\") {\n137\t    text = String(c[\"text\"] ?? c[\"summary\"] ?? c[\"title\"] ?? JSON.stringify(c));\n138\t  }\n139\t  text = text.replace(/\\s+/g, \" \").trim();\n140\t  return text.length > 100 ? text.slice(0, 97) + \"...\" : text;\n141\t}\n142\t\n143\tfunction printHuman(events: EvidenceEvent[]): void {\n144\t  for (const e of events) {\n145\t    const conv = e.conversation ? `${e.conversation.id.slice(0, 28)}#${e.conversation.seq}` : \"-\";\n146\t    const role =\n147\t      (e.content as Record<string, unknown> | null | undefined) &&\n148\t      typeof e.content === \"object\"\n149\t        ? String((e.content as Record<string, unknown>)[\"role\"] ?? e.actor.type)\n150\t        : e.actor.type;\n151\t    process.stdout.write(\n152\t      `${e.occurred_at}  ${e.kind}  ${role.padEnd(9)}  ${conv}  ${snippet(e)}\\n`,\n153\t    );\n154\t  }\n155\t}\n156\t\n157\tfunction printJsonl(events: EvidenceEvent[], includeRaw: boolean): void {\n158\t  for (const e of events) {\n159\t    const out = includeRaw ? e : { ...e, raw: undefined };\n160\t    process.stdout.write(JSON.stringify(out) + \"\\n\");\n161\t  }\n162\t}\n163\t\n164\tasync function cmdAppend(flags: Flags): Promise<void> {\n165\t  const repo = await requireRepo();\n166\t  const body = await readStdin();\n167\t  const drafts: EventDraft[] = body\n168\t    .split(\"\\n\")\n169\t    .filter((l) => l.trim())\n170\t    .map((l) => JSON.parse(l) as EventDraft);\n171\t  if (drafts.length === 0) return;\n172\t  const result = await appendEvents(repo, drafts);\n173\t  if (!flags[\"quiet\"]) {\n174\t    for (const e of result.appended) process.stdout.write(e.id + \"\\n\");\n175\t    process.stderr.write(\n176\t      `appended ${result.appended.length}, deduped ${result.deduped}` +\n177\t        (result.anchor ? ` (anchor ${result.anchor.slice(0, 12)})` : \" (pending: no commits yet)\") +\n178\t        \"\\n\",\n179\t    );\n180\t  }\n181\t}\n182\t\n183\tasync function cmdLog(flags: Flags): Promise<void> {\n184\t  const repo = await requireRepo();\n185\t  const events = await readEvents(repo, readOptionsFrom(flags));\n186\t  if (flags[\"json\"]) printJsonl(events, false);\n187\t  else printHuman(events);\n188\t}\n189\t\n190\tasync function cmdShow(positional: string[], flags: Flags): Promise<void> {\n191\t  const prefix = positional[0];\n192\t  if (!prefix) {\n193\t    process.stderr.write(\"usage: cledger show <conversation-id-prefix>\\n\");\n194\t    process.exit(2);\n195\t  }\n196\t  const repo = await requireRepo();\n197\t  const events = await readEvents(repo, { conversation: prefix });\n198\t  if (events.length === 0) {\n199\t    process.stderr.write(`no events for conversation ${prefix}\\n`);\n200\t    process.exit(1);\n201\t  }\n202\t  if (flags[\"json\"]) {\n203\t    printJsonl(events, true);\n204\t    return;\n205\t  }\n206\t  for (const e of sortEvents(events)) {\n207\t    const c = e.content as Record<string, unknown>;\n208\t    const role = typeof c === \"object\" && c ? String(c[\"role\"] ?? e.actor.type) : e.actor.type;\n209\t    const tex