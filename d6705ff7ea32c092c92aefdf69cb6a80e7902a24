t =\n210\t      typeof c === \"object\" && c && typeof c[\"text\"] === \"string\"\n211\t        ? (c[\"text\"] as string)\n212\t        : JSON.stringify(e.content, null, 2);\n213\t    process.stdout.write(`\\n[${e.occurred_at}] ${role} (${e.kind}, ${e.id.slice(0, 16)})\\n`);\n214\t    process.stdout.write(text.trimEnd() + \"\\n\");\n215\t  }\n216\t}\n217\t\n218\tasync function cmdConversations(flags: Flags): Promise<void> {\n219\t  const repo = await requireRepo();\n220\t  const events = await readEvents(repo, readOptionsFrom(flags));\n221\t  const byConv = new Map<string, { count: number; first: string; last: string; source: string }>();\n222\t  for (const e of events) {\n223\t    const id = e.conversation?.id ?? \"(none)\";\n224\t    const entry = byConv.get(id) ?? {\n225\t      count: 0,\n226\t      first: e.occurred_at,\n227\t      last: e.occurred_at,\n228\t      source: e.producer.source ?? e.producer.tool,\n229\t    };\n230\t    entry.count++;\n231\t    if (e.occurred_at < entry.first) entry.first = e.occurred_at;\n232\t    if (e.occurred_at > entry.last) entry.last = e.occurred_at;\n233\t    byConv.set(id, entry);\n234\t  }\n235\t  for (const [id, s] of [...byConv.entries()].sort((a, b) => a[1].last.localeCompare(b[1].last))) {\n236\t    process.stdout.write(`${id}  ${s.source}  ${s.count} events  ${s.first} .. ${s.last}\\n`);\n237\t  }\n238\t}\n239\t\n240\tasync function cmdExport(flags: Flags): Promise<void> {\n241\t  const repo = await requireRepo();\n242\t  const opts: ReadOptions = {};\n243\t  if (typeof flags[\"rev\"] === \"string\") opts.reachableFrom = flags[\"rev\"];\n244\t  const events = await readEvents(repo, opts);\n245\t  printJsonl(events, true);\n246\t}\n247\t\n248\tasync function cmdSync(flags: Flags): Promise<void> {\n249\t  const repo = await requireRepo();\n250\t  const remote = typeof flags[\"remote\"] === \"string\" ? flags[\"remote\"] : \"origin\";\n251\t  const mode = flags[\"push\"] ? \"push\" : flags[\"fetch\"] ? \"fetch\" : \"both\