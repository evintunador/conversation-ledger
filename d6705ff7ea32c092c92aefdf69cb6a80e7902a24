gnized(source: string, unrecognized: Record<string, number>): void {\n74\t  const entries = Object.entries(unrecognized);\n75\t  if (entries.length === 0) return;\n76\t  const total = entries.reduce((n, [, c]) => n + c, 0);\n77\t  const detail = entries\n78\t    .sort((a, b) => b[1] - a[1])\n79\t    .map(([type, count]) => `${type} x${count}`)\n80\t    .join(\", \");\n81\t  process.stderr.write(\n82\t    `cledger: ${source} preserved ${total} transcript line(s) of unrecognized type (${detail}) ` +\n83\t      `raw-only — the ${source} format may have added content this cledger version cannot ` +\n84\t      `interpret; update conversation-ledger to normalize these, or report it\\n`,\n85\t  );\n86\t}\n87\t","tool_use_id":"toolu_01VAL5gniQ79A2Y1usudH5kV","type":"tool_result"}],"role":"user"},"parentUuid":"d5425a6a-e729-4953-b353-5d181ac17424","promptId":"e9372d31-57ff-4125-b67f-98829080b1b4","sessionId":"ca50d7db-8621-495c-a94a-c3d3ab731073","session_id":"ca50d7db-8621-495c-a94a-c3d3ab731073","slug":"fluttering-brewing-bachman","sourceToolAssistantUUID":"d5425a6a-e729-4953-b353-5d181ac17424","timestamp":"2026-07-22T18:24:35.525Z","toolUseResult":{"file":{"content":"/**\n * Format-drift handling shared by adapters. Adapters are tolerant parsers:\n * a line type in neither the convertible set nor the deliberately-skipped set\n * is *unrecognized* — most likely new upstream content this cledger version\n * has no mapping for. Two things happen for such a line:\n *\n *  1. It is counted per type and surfaced in a capture-time warning (the\n *     drift tripwire — \"the format changed, update cledger\").\n *  2. It is preserved raw-only as an `unrecognized` event (see\n *     `unrecognizedDraft`) instead of being dropped, so a later adapter\n *     version can re-normalize the line rather than lose it forever.\n *\n * Preservation events ride the normal append path, so the capture-time\n * redaction stack walks their `raw.data` exactly as it does interpreted\n * events — an 