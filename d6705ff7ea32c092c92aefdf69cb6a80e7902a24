{"actor":{"display":"Evin Tunador","id":"evintunador@gmail.com","type":"human"},"content":{"blocks":[{"content":"120\t  return Buffer.concat(chunks).toString(\"utf8\");\n121\t}\n122\t\n123\tfunction readOptionsFrom(flags: Flags): ReadOptions {\n124\t  const opts: ReadOptions = {};\n125\t  if (!flags[\"all\"]) opts.reachableFrom = typeof flags[\"rev\"] === \"string\" ? flags[\"rev\"] : \"HEAD\";\n126\t  if (typeof flags[\"kind\"] === \"string\") opts.kind = flags[\"kind\"];\n127\t  if (typeof flags[\"source\"] === \"string\") opts.source = flags[\"source\"];\n128\t  if (typeof flags[\"conversation\"] === \"string\") opts.conversation = flags[\"conversation\"];\n129\t  return opts;\n130\t}\n131\t\n132\tfunction snippet(event: EvidenceEvent): string {\n133\t  const c = event.content as Record<string, unknown> | string | null;\n134\t  let text = \"\";\n135\t  if (typeof c === \"string\") text = c;\n136\t  else if (c && typeof c === \"object\") {\n137\t    text = String(c[\"text\"] ?? c[\"summary\"] ?? c[\"title\"] ?? JSON.stringify(c));\n138\t  }\n139\t  text = text.replace(/\\s+/g, \" \").trim();\n140\t  return text.length > 100 ? text.slice(0, 97) + \"...\" : text;\n141\t}\n142\t\n143\tfunction printHuman(events: EvidenceEvent[]): void {\n144\t  for (const e of events) {\n145\t    const conv = e.conversation ? `${e.conversation.id.slice(0, 28)}#${e.conversation.seq}` : \"-\";\n146\t    const role =\n147\t      (e.content as Record<string, unknown> | null | undefined) &&\n148\t      typeof e.content === \"object\"\n149\t        ? String((e.content as Record<string, unknown>)[\"role\"] ?? e.actor.type)\n150\t        : e.actor.type;\n151\t    process.stdout.write(\n152\t      `${e.occurred_at}  ${e.kind}  ${role.padEnd(9)}  ${conv}  ${snippet(e)}\\n`,\n153\t    );\n154\t  }\n155\t}\n156\t\n157\tfunction printJsonl(events: EvidenceEvent[], includeRaw: boolean): void {\n158\t  for (const e of events) {\n159\t    const out = includeRaw ? e : { ...e, raw: undefined };\n160\t