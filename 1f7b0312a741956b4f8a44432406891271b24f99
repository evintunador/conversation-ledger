n` event.","+- **Sub-turn citation anchors** for downstream consumers like intent-recall.","+"," ## Storage model, in one paragraph"," "," One git note per anchor commit under `refs/notes/conversation-ledger`; the"],"newLines":38,"newStart":51,"oldLines":6,"oldStart":51}],"userModified":false},"type":"user","userType":"external","uuid":"f7648245-53b5-4d97-b9ca-2d721978649f","version":"2.1.214"},"format":"claude-code-jsonl/1"},"recorded_at":"2026-07-18T23:25:38.976Z","schema":"conversation-ledger/v1"}
