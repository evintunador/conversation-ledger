t: string, start: number, end: number): string {\n45\t  const masked = maskMatch(text.slice(start, end));\n46\t  const pre = text.slice(Math.max(0, start - 20), start);\n47\t  const post = text.slice(end, end + 20);\n48\t  return `${pre}${masked}${post}`.replace(/\\s+/g, \" \").trim();\n49\t}\n50\t\n51\tconst PURE_HEX_RE = /^[0-9a-fA-F]+$/;\n52\t\n53\t/**\n54\t * Scan already-finalized events for potential secrets. Read-only: never\n55\t * mutates content, only reports. `tier` selects the ruleset — \"standard\"\n56\t * re-runs the full capture ruleset plus scan-only keyword/URL/bearer rules\n57\t * (catching events captured under an older capture ruleset); \"paranoid\"\n58\t * additionally enables the entropy-gated high-entropy-token rule.\n59\t */\n60\texport function scanEvents(events: EvidenceEvent[], tier: \"standard\" | \"paranoid\"): Finding[] {\n61\t  const rules = rulesForTier(tier);\n62\t  const findings: Finding[] = [];\n63\t\n64\t  for (const event of events) {\n65\t    const visit = (value: string, _path: string): string => {\n66\t      for (const rule of rules) {\n67\t        for (const m of value.matchAll(rule.pattern)) {\n68\t          const matchText = m[0];\n69\t          const start = m.index ?? 0;\n70\t          const end = start + matchText.length;\n71\t          if (overlapsPlaceholder(value, start, end)) continue;\n72\t          if (rule.entropyGated) {\n73\t            // Belt-and-suspenders: rulesForTier already excludes this rule\n74\t            // below \"paranoid\", but the gate is cheap to state explicitly.\n75\t            if (tier !== \"paranoid\") continue;\n76\t            if (PURE_HEX_RE.test(matchText)) continue; // git SHAs, content digests\n77\t            if (matchText.includes(\"[REDACTED:\")) continue;\n78\t            if (shannonEntropy(matchText) < 4.0) continue;\n79\t          }\n80\t          findings.push({\n81\t            eventId: event.id,\n82\t            ...(event.conversation ? { conversation: event.conversation.id 